{
  "name": "leftover-food-management-system",
  "version": "1.0.0",
  "description": "A real-time food donation and tracking system connecting donors with NGOs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "bump": "node scripts/bump-version.js",
    "deploy": "node scripts/bump-version.js && git add . && git commit -m \"Update v$(date +%Y%m%d-%H%M)\" && git push",
    "create-admin": "node scripts/create-admin.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "express-session": "^1.17.3",
    "connect-mongo": "^5.0.0",
    "ejs": "^3.1.9",
    "body-parser": "^1.20.2",
    "method-override": "^3.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}