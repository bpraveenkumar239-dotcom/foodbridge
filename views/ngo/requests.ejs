<%- include('../partials/header', {title: 'Donation Requests – FoodBridge'}) %>
<%- include('../partials/navbar') %>

<div class="page-section">
  <div class="container py-5">
    <div class="section-header">
      <h2 class="section-title"><i class="bi bi-list-check me-2"></i>Donation Requests</h2>
      <p class="section-subtitle">Review and manage food donation requests from donors</p>
    </div>

    <ul class="nav nav-tabs-custom mb-4">
      <li><button class="tab-btn active" data-target="pending-section">
        <i class="bi bi-hourglass-split me-1"></i>Pending (<%= pending.length %>)
      </button></li>
      <li><button class="tab-btn" data-target="accepted-section">
        <i class="bi bi-truck me-1"></i>My Active (<%= myAccepted.length %>)
      </button></li>
    </ul>

    <% const catEmojis={cooked:'🥘',raw:'🥦',packaged:'📦',bakery:'🥖',fruits_veg:'🍎',dairy:'🥛',other:'🍱'}; %>

    <!-- PENDING -->
    <div id="pending-section" class="tab-section">
      <% if (pending.length === 0) { %>
        <div class="empty-state"><div class="empty-icon">📭</div><h4>No pending requests</h4><p>All caught up! Check back later.</p></div>
      <% } else { %>
        <div class="requests-grid">
          <% pending.forEach(d => {
            const expiringSoon = d.expiresAt && (new Date(d.expiresAt) - Date.now()) < 2*3600*1000 && new Date(d.expiresAt) > Date.now();
          %>
            <div class="request-card <%= expiringSoon ? 'card-expiring' : '' %>">
              <div class="request-card-header">
                <span class="food-badge"><%= catEmojis[d.category]||'🍱' %> <%= d.name %></span>
                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                  <span class="status-badge status-pending">Pending</span>
                  <% if (expiringSoon) { %><span style="background:#fee2e2;color:#991b1b;padding:3px 8px;border-radius:12px;font-size:.7rem;font-weight:700;">⏰ Expiring!</span><% } %>
                </div>
              </div>
              <div class="request-details">
                <div class="detail-row"><i class="bi bi-box"></i><span>Qty: <strong><%= d.quantity %></strong><% if(d.servings){ %> · ~<%= d.servings %> servings<% } %></span></div>

                <div class="detail-row donor-contact-row">
                  <i class="bi bi-person-fill"></i>
                  <span>
                    <strong><%= d.donorName %></strong>
                    <% if (d.donorPhone) { %>
                      &nbsp;·&nbsp;<a href="tel:<%= d.donorPhone %>" class="donor-phone-link"><i class="bi bi-telephone-fill me-1"></i><%= d.donorPhone %></a>
                    <% } else { %>
                      <span class="text-muted"> · No phone</span>
                    <% } %>
                  </span>
                </div>

                <div class="detail-row"><i class="bi bi-geo-alt"></i><span><strong>Pickup:</strong> <%= d.pickupLocation.length > 55 ? d.pickupLocation.substring(0,55)+'…' : d.pickupLocation %></span></div>

                <% if (d.deliveryLocation) { %>
                  <div class="detail-row text-success"><i class="bi bi-send-check"></i><span><strong>Delivery:</strong> <%= d.deliveryLocation.length > 55 ? d.deliveryLocation.substring(0,55)+'…' : d.deliveryLocation %></span></div>
                <% } else { %>
                  <div class="detail-row delivery-unset-row"><i class="bi bi-send-x"></i><span>No delivery set — NGO chooses after pickup</span></div>
                <% } %>

                <% if (d.tags && d.tags.length) { %>
                  <div class="detail-row"><i class="bi bi-tags"></i><span><% d.tags.forEach(t => { %><span style="background:#e8f5ee;color:#1a4a2e;padding:2px 7px;border-radius:8px;font-size:.7rem;font-weight:600;margin-right:4px;">#<%= t %></span><% }) %></span></div>
                <% } %>

                <% if (d.expiresAt) { %>
                  <div class="detail-row" style="color:<%= new Date(d.expiresAt) < new Date() ? '#ef4444' : '#f59e0b' %>;">
                    <i class="bi bi-clock"></i><span>Expires: <%= new Date(d.expiresAt).toLocaleString('en-IN',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %></span>
                  </div>
                <% } %>

                <% if (d.description) { %>
                  <div class="detail-row"><i class="bi bi-chat-text"></i><span><%= d.description %></span></div>
                <% } %>
                <div class="detail-row"><i class="bi bi-clock-history"></i><span><%= new Date(d.createdAt).toLocaleString('en-IN') %></span></div>
              </div>
              <div class="request-actions">
                <form action="/ngo/accept/<%= d._id %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-accept"><i class="bi bi-check-circle me-1"></i>Accept</button>
                </form>
                <form action="/ngo/reject/<%= d._id %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-reject" onclick="return confirm('Reject this donation?')"><i class="bi bi-x-circle me-1"></i>Reject</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- MY ACTIVE -->
    <div id="accepted-section" class="tab-section" style="display:none;">
      <% if (myAccepted.length === 0) { %>
        <div class="empty-state"><div class="empty-icon">🚗</div><h4>No active deliveries</h4><p>Accept a pending request to start a delivery.</p></div>
      <% } else { %>
        <div class="requests-grid">
          <% myAccepted.forEach(d => {
            const hasDelivery = d.deliveryLocation || d.ngoDeliveryLocation;
            const deliveryLabel = d.deliveryLocation || d.ngoDeliveryLocation;
            const byNGO = !d.deliveryLocation && d.ngoDeliveryLocation;
            const donorRated = d.ratings && d.ratings.some(r => r.byRole === 'ngo');
          %>
            <div class="request-card">
              <div class="request-card-header">
                <span class="food-badge"><%= catEmojis[d.category]||'🍱' %> <%= d.name %></span>
                <span class="status-badge status-<%= d.status %>"><%= d.status === 'accepted' ? 'Accepted' : 'In Transit' %></span>
              </div>
              <div class="request-details">
                <div class="detail-row"><i class="bi bi-box"></i><span>Qty: <strong><%= d.quantity %></strong><% if(d.servings){ %> · ~<%= d.servings %> servings<% } %></span></div>

                <div class="detail-row donor-contact-row">
                  <i class="bi bi-person-fill"></i>
                  <span><strong><%= d.donorName %></strong>
                    <% if(d.donorPhone){ %>&nbsp;·&nbsp;<a href="tel:<%= d.donorPhone %>" class="donor-phone-link"><i class="bi bi-telephone-fill me-1"></i><%= d.donorPhone %></a><% } %>
                  </span>
                </div>

                <div class="detail-row"><i class="bi bi-geo-alt"></i><span><strong>Pickup:</strong> <%= d.pickupLocation.length>50?d.pickupLocation.substring(0,50)+'…':d.pickupLocation %></span></div>

                <% if (hasDelivery) { %>
                  <div class="detail-row <%= byNGO?'text-primary':'text-success' %>">
                    <i class="bi bi-<%= byNGO?'pin-map-fill':'send-check' %>"></i>
                    <span><strong><%= byNGO?'Your Delivery:':'Donor Delivery:' %></strong> <%= deliveryLabel.length>48?deliveryLabel.substring(0,48)+'…':deliveryLabel %></span>
                  </div>
                <% } else { %>
                  <div class="detail-row delivery-unset-row"><i class="bi bi-send-x"></i><span>No delivery set yet</span></div>
                <% } %>

                <!-- Latest note preview -->
                <% if (d.notes && d.notes.length > 0) { %>
                  <div style="margin-top:4px;background:#fef9c3;border-radius:8px;padding:7px 10px;font-size:.75rem;">
                    <i class="bi bi-chat-text me-1 text-warning"></i>
                    <strong><%= d.notes[d.notes.length-1].author %>:</strong>
                    "<%= d.notes[d.notes.length-1].message.substring(0,55) %><%= d.notes[d.notes.length-1].message.length>55?'…':'' %>"
                  </div>
                <% } %>
              </div>

              <div class="request-actions flex-wrap gap-2">
                <a href="/ngo/navigate/<%= d._id %>" class="btn btn-navigate flex-fill"><i class="bi bi-map me-1"></i>Navigate</a>
                <% if (!hasDelivery) { %>
                  <a href="/ngo/set-delivery/<%= d._id %>" class="btn btn-set-delivery flex-fill"><i class="bi bi-pin-map me-1"></i>Set Delivery</a>
                <% } else { %>
                  <a href="/ngo/set-delivery/<%= d._id %>" class="btn btn-set-delivery-edit flex-fill"><i class="bi bi-pencil me-1"></i>Change</a>
                <% } %>
                <button class="btn-note-small" onclick="openNGONoteModal('<%= d._id %>')"><i class="bi bi-chat-plus"></i></button>
                <% if (d.status === 'delivered' && !donorRated) { %>
                  <button class="btn-rate-small" onclick="openNGORateModal('<%= d._id %>','<%= d.name.replace(/'/g,'') %>')"><i class="bi bi-star"></i></button>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- NGO Note Modal -->
<div class="modal fade" id="ngoNoteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">💬 Add Note for Donor</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <form id="ngoNoteForm" method="POST">
        <div class="modal-body">
          <textarea name="message" class="form-control" rows="4" placeholder="Leave a message for the donor…" required style="border-radius:10px;border:2px solid #e5e7eb;"></textarea>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary" style="background:#1a4a2e;border:none;">Send Note</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- NGO Rate Modal -->
<div class="modal fade" id="ngoRateModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">⭐ Rate Food Quality</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <form id="ngoRateForm" method="POST">
        <div class="modal-body">
          <p>Rate food quality for: <strong id="ngoRateFoodName"></strong></p>
          <div class="star-picker mb-3">
            <% for(let s=5;s>=1;s--){ %>
              <input type="radio" name="stars" value="<%= s %>" id="ngoStar<%= s %>"/>
              <label for="ngoStar<%= s %>"><i class="bi bi-star-fill"></i></label>
            <% } %>
          </div>
          <textarea name="comment" class="form-control" rows="3" placeholder="Any feedback? (optional)…" style="border-radius:10px;border:2px solid #e5e7eb;"></textarea>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-warning">Submit Rating</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
.card-expiring { border-color:#fca5a5 !important; background:#fff5f5; }
.donor-contact-row { align-items:center; }
.donor-phone-link { color:#1a4a2e;font-weight:600;text-decoration:none;background:#e8f5ee;padding:2px 10px;border-radius:20px;font-size:.82rem;display:inline-flex;align-items:center;transition:all .2s; }
.donor-phone-link:hover { background:#1a4a2e;color:#fff; }
.delivery-unset-row { color:#f59e0b;font-style:italic;font-size:.84rem; }
.btn-set-delivery { background:#f59e0b;color:#fff;border-radius:8px;padding:10px;font-weight:600;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;transition:all .2s;border:none;font-size:.9rem; }
.btn-set-delivery:hover { background:#d97706;color:#fff; }
.btn-set-delivery-edit { background:#e0f2fe;color:#0369a1;border:2px solid #7dd3fc;border-radius:8px;padding:10px;font-weight:600;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;transition:all .2s;font-size:.9rem; }
.btn-set-delivery-edit:hover { background:#7dd3fc;color:#0369a1; }
.btn-note-small { background:#fef9c3;color:#92400e;border:1.5px solid #fde68a;border-radius:8px;padding:8px 12px;cursor:pointer;transition:all .2s;font-size:.9rem; }
.btn-note-small:hover { background:#fde68a; }
.btn-rate-small { background:#fef3c7;color:#92400e;border:1.5px solid #fbbf24;border-radius:8px;padding:8px 12px;cursor:pointer;transition:all .2s;font-size:.9rem; }
.btn-rate-small:hover { background:#fbbf24; }
.star-picker { display:flex;flex-direction:row-reverse;justify-content:flex-end;gap:4px; }
.star-picker input[type=radio] { display:none; }
.star-picker label { font-size:1.8rem;cursor:pointer;color:#d1d5db;transition:color .1s; }
.star-picker input:checked ~ label,.star-picker label:hover,.star-picker label:hover ~ label { color:#f59e0b; }
</style>

<script>
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.tab-section').forEach(s=>s.style.display='none');
    this.classList.add('active');
    document.getElementById(this.dataset.target).style.display = 'block';
  });
});
function openNGONoteModal(id) {
  document.getElementById('ngoNoteForm').action = '/ngo/note/' + id;
  document.getElementById('ngoNoteModal').querySelector('textarea').value = '';
  new bootstrap.Modal(document.getElementById('ngoNoteModal')).show();
}
function openNGORateModal(id, name) {
  document.getElementById('ngoRateFoodName').textContent = name;
  document.getElementById('ngoRateForm').action = '/ngo/rate/' + id;
  new bootstrap.Modal(document.getElementById('ngoRateModal')).show();
}
</script>

<%- include('../partials/footer') %>
