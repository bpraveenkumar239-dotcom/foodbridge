<%- include('../partials/header', {title: 'Set Delivery Location – FoodBridge'}) %>
<%- include('../partials/navbar') %>

<div class="page-section">
  <div class="container py-5">
    <a href="/ngo/requests" class="back-link mb-3 d-inline-flex"><i class="bi bi-arrow-left me-2"></i>Back to Requests</a>

    <% const isOverride = !!(food.deliveryLocation); %>

    <div class="section-header">
      <h2 class="section-title">
        <i class="bi bi-<%= isOverride ? 'arrow-repeat' : 'pin-map' %> me-2"></i>
        <%= isOverride ? 'Override Delivery Location' : 'Set Delivery Location' %>
      </h2>
      <p class="section-subtitle">
        <% if (isOverride) { %>
          The donor already set a delivery location. You can change it to a more suitable or accessible location — the donor will be notified.
        <% } else { %>
          The donor didn't set a delivery location. Choose where to deliver the food to those in need.
        <% } %>
      </p>
    </div>

    <!-- Donation summary -->
    <div class="donation-summary-card mb-4">
      <div class="row align-items-start g-2">
        <div class="col-auto"><span style="font-size:2rem;">🍱</span></div>
        <div class="col">
          <h5 class="mb-1"><%= food.name %> — <strong><%= food.quantity %></strong></h5>
          <p class="mb-1 text-muted small"><i class="bi bi-person me-1"></i>Donor: <strong><%= food.donorName %></strong>
            <% if (food.donorPhone) { %>
              &nbsp;<a href="tel:<%= food.donorPhone %>" style="color:#1a4a2e;font-weight:600;text-decoration:none;background:#e8f5ee;padding:2px 10px;border-radius:20px;font-size:.82rem;">
                <i class="bi bi-telephone-fill me-1"></i><%= food.donorPhone %>
              </a>
            <% } %>
          </p>
          <p class="mb-1 text-muted small"><i class="bi bi-geo-alt me-1"></i>Pickup: <%= food.pickupLocation %></p>

          <% if (food.deliveryLocation) { %>
            <div style="background:#fef9c3;border:1.5px solid #fde68a;border-radius:8px;padding:8px 12px;margin-top:6px;font-size:.85rem;">
              <i class="bi bi-send-check me-1 text-warning"></i>
              <strong>Donor's delivery:</strong> <%= food.deliveryLocation %>
              <% if (food.ngoDeliveryLocation && food.ngoOverrideDelivery) { %>
                <br/><i class="bi bi-arrow-repeat me-1 text-primary"></i>
                <strong>Your override:</strong> <%= food.ngoDeliveryLocation %>
              <% } %>
            </div>
          <% } else if (food.ngoDeliveryLocation) { %>
            <div style="background:#eff6ff;border:1.5px solid #bfdbfe;border-radius:8px;padding:8px 12px;margin-top:6px;font-size:.85rem;">
              <i class="bi bi-pin-map-fill me-1 text-primary"></i>
              <strong>Current delivery (you set):</strong> <%= food.ngoDeliveryLocation %>
            </div>
          <% } %>
        </div>
        <div class="col-auto">
          <span class="status-badge status-<%= food.status %>"><%= food.status.replace('_',' ').toUpperCase() %></span>
        </div>
      </div>
    </div>

    <% if (!isOverride) { %>
    <div class="alert alert-info d-flex align-items-start gap-3 mb-4" style="border-radius:14px;border:2px solid #60a5fa;">
      <span style="font-size:1.8rem;">💡</span>
      <div style="font-size:.88rem;">
        <strong>Suggested delivery locations:</strong>
        <ul class="mb-0 mt-1">
          <li>Government shelters, orphanages, old-age homes</li>
          <li>Railway stations or bus stands with homeless population</li>
          <li>Anganwadi centres, government schools</li>
          <li>Community kitchens or NGO feeding points</li>
        </ul>
      </div>
    </div>
    <% } %>


    <!-- Needy Locations Panel -->
    <div id="needyPanel" class="mb-4">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
        <h5 style="font-family:'DM Sans',sans-serif;font-weight:700;margin:0;color:#1a4a2e;">
          <i class="bi bi-heart-fill text-danger me-2"></i>Suggested Needy Locations
          <span id="needyCount" style="background:#e8f5ee;color:#1a4a2e;font-size:.72rem;padding:2px 10px;border-radius:12px;margin-left:8px;font-weight:700;"></span>
        </h5>
        <button type="button" onclick="toggleNeedyMap()" style="background:#f3f4f6;border:2px solid #e5e7eb;border-radius:10px;padding:7px 16px;font-size:.82rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;">
          <i class="bi bi-map me-1"></i>Show on Map
        </button>
      </div>
      <div id="needyLoading" style="text-align:center;padding:20px;color:#9ca3af;">
        <div class="spinner-border spinner-border-sm text-success me-2"></div>Loading needy locations…
      </div>
      <div id="needyGrid" style="display:none;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px;margin-bottom:14px;"></div>
      <div id="needyMapNGO" style="display:none;height:280px;border-radius:14px;overflow:hidden;border:2px solid #e5e7eb;margin-bottom:14px;"></div>
    </div>

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
      <div style="flex:1;height:1px;background:#e5e7eb;"></div>
      <span style="font-size:.82rem;color:#9ca3af;font-weight:600;">OR ENTER MANUALLY</span>
      <div style="flex:1;height:1px;background:#e5e7eb;"></div>
    </div>

    <div class="form-card">
      <form action="/ngo/set-delivery/<%= food._id %>" method="POST" id="setDeliveryForm">

        <!-- If override — show reason field prominently -->
        <% if (isOverride) { %>
        <div class="mb-4 p-3" style="background:#fff7ed;border:2px solid #fed7aa;border-radius:12px;">
          <label class="form-label fw-bold"><i class="bi bi-chat-text me-1 text-orange"></i>Reason for Changing Donor's Delivery Location <span class="text-muted">(optional, shared with donor)</span></label>
          <input type="text" class="form-control fc-custom" name="ngoOverrideNote"
            placeholder="e.g. More accessible location, closer to shelter, road blocked…"/>
        </div>
        <% } else { %>
        <input type="hidden" name="ngoOverrideNote" value=""/>
        <% } %>

        <div class="col-12">
          <label class="form-label fw-bold">
            <% if (isOverride) { %>New Delivery Location *<% } else { %>Delivery / Needy Location *<% } %>
          </label>
          <div class="location-selector">
            <div class="location-tabs">
              <button type="button" class="loc-tab active" data-method="manual"><i class="bi bi-keyboard"></i> Type Address</button>
              <button type="button" class="loc-tab" data-method="live"><i class="bi bi-geo-alt-fill"></i> My Location</button>
              <button type="button" class="loc-tab" data-method="map"><i class="bi bi-map"></i> Pick on Map</button>
            </div>

            <div class="location-input-area mt-2">
              <input type="text" class="form-control fc-custom" name="ngoDeliveryLocation"
                id="delivLocText"
                placeholder="<%= isOverride ? 'Enter new delivery address…' : 'e.g. XYZ Shelter, Church Street, Bengaluru' %>"
                value="<%= food.ngoDeliveryLocation || '' %>" required/>
              <input type="hidden" name="ngoDeliveryLatitude"  id="delivLat" value="<%= food.ngoDeliveryLatitude  || '' %>"/>
              <input type="hidden" name="ngoDeliveryLongitude" id="delivLng" value="<%= food.ngoDeliveryLongitude || '' %>"/>

              <div id="liveStatus" class="location-status mt-2" style="display:none;">
                <div class="spinner-border spinner-border-sm text-success me-2"></div>Detecting your location…
              </div>

              <div id="mapContainer" class="map-container mt-3" style="display:none;">
                <div id="delivMap" style="height:350px;border-radius:12px;"></div>
                <p class="map-hint"><i class="bi bi-cursor me-1"></i>Click anywhere on the map to set delivery point</p>
              </div>
            </div>
          </div>
        </div>

        <div class="form-actions mt-4">
          <button type="submit" class="btn btn-primary btn-lg btn-submit">
            <i class="bi bi-check2-circle me-2"></i>
            <%= isOverride ? 'Save New Delivery Location' : 'Save Delivery Location' %>
          </button>
          <a href="/ngo/navigate/<%= food._id %>" class="btn btn-ghost ms-3">Skip & Navigate</a>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
.text-orange { color:#f97316; }
</style>

<script>
let delivMap = null, delivMarker = null;

document.querySelectorAll('.loc-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.loc-tab').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    const method = this.dataset.method;
    document.getElementById('liveStatus').style.display  = 'none';
    document.getElementById('mapContainer').style.display = 'none';

    if (method === 'live') {
      document.getElementById('liveStatus').style.display = 'flex';
      navigator.geolocation.getCurrentPosition(pos => {
        const lat = pos.coords.latitude, lng = pos.coords.longitude;
        document.getElementById('delivLat').value = lat;
        document.getElementById('delivLng').value = lng;
        reverseGeocode(lat, lng, 'delivLocText');
        document.getElementById('liveStatus').style.display = 'none';
      }, () => {
        document.getElementById('liveStatus').innerHTML = '<i class="bi bi-x-circle text-danger me-2"></i>Location denied.';
      });
    } else if (method === 'map') {
      document.getElementById('mapContainer').style.display = 'block';
      if (!delivMap) {
        delivMap = L.map('delivMap').setView([12.9716, 77.5946], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution:'© OpenStreetMap' }).addTo(delivMap);
        delivMap.on('click', function(e) {
          const lat = e.latlng.lat, lng = e.latlng.lng;
          if (delivMarker) delivMap.removeLayer(delivMarker);
          delivMarker = L.marker([lat, lng], {
            icon: L.divIcon({ className:'', html:'<div style="background:#3b82f6;width:24px;height:24px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;font-size:12px;">🏠</div>', iconSize:[24,24], iconAnchor:[12,12] })
          }).addTo(delivMap).bindPopup('Delivery point').openPopup();
          document.getElementById('delivLat').value = lat;
          document.getElementById('delivLng').value = lng;
          reverseGeocode(lat, lng, 'delivLocText');
        });
      } else { setTimeout(() => delivMap.invalidateSize(), 100); }
    }
  });
});

function reverseGeocode(lat, lng, id) {
  fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`)
    .then(r => r.json())
    .then(d => { document.getElementById(id).value = d.display_name || `${lat.toFixed(5)}, ${lng.toFixed(5)}`; })
    .catch(() => { document.getElementById(id).value = `${lat.toFixed(5)}, ${lng.toFixed(5)}`; });
}

// Pre-place existing marker if coords available
window.addEventListener('load', function() {
  const lat = parseFloat('<%= food.ngoDeliveryLatitude || "" %>');
  const lng = parseFloat('<%= food.ngoDeliveryLongitude || "" %>');
  // show on map if tab is active (it isn't by default, just init silently)
});

document.getElementById('setDeliveryForm').addEventListener('submit', function(e) {
  if (!document.getElementById('delivLocText').value.trim()) {
    e.preventDefault(); alert('Please enter or pick a delivery location.');
  }
});
</script>


<style>
.needy-card{background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:12px 14px;cursor:pointer;transition:all .2s;position:relative;}
.needy-card:hover{border-color:#22c55e;box-shadow:0 4px 16px rgba(34,197,94,.15);}
.needy-card.selected{border-color:#1a4a2e;background:#f0fdf4;}
.needy-card .sel-badge{display:none;position:absolute;top:8px;right:8px;background:#1a4a2e;color:#fff;font-size:.62rem;font-weight:700;padding:2px 7px;border-radius:10px;}
.needy-card.selected .sel-badge{display:block;}
</style>
<script>
const _catEmojis={orphanage:'🏠',shelter:'🏕️',oldage:'👴',school:'🏫',hospital:'🏥',community:'🤝',station:'🚉',other:'📍'};
const _catColors={orphanage:'#dbeafe',shelter:'#dcfce7',oldage:'#fef3c7',school:'#ede9fe',hospital:'#fee2e2',community:'#e0f2fe',station:'#fdf4ff',other:'#f3f4f6'};
const _catText  ={orphanage:'#1e40af',shelter:'#065f46',oldage:'#92400e',school:'#5b21b6',hospital:'#991b1b',community:'#0369a1',station:'#7e22ce',other:'#374151'};
const _pinColor ={orphanage:'#3b82f6',shelter:'#22c55e',oldage:'#f59e0b',school:'#8b5cf6',hospital:'#ef4444',community:'#06b6d4',station:'#a855f7',other:'#6b7280'};

let _allLocs=[], _ngoNeedyMap=null, _ngoNeedyInited=false;

fetch('/api/needy-locations').then(r=>r.json()).then(data=>{
  document.getElementById('needyLoading').style.display='none';
  if(!data.success||!data.locations.length){
    document.getElementById('needyGrid').style.display='block';
    document.getElementById('needyGrid').innerHTML='<p style="color:#9ca3af;font-size:.82rem;">No needy locations added by admin yet.</p>';
    return;
  }
  _allLocs=data.locations;
  document.getElementById('needyCount').textContent=data.locations.length+' locations';
  const grid=document.getElementById('needyGrid');
  grid.style.display='grid';
  grid.innerHTML=_allLocs.map(loc=>`
    <div class="needy-card" id="nnc_${loc._id}" onclick="_selectNeedy('${loc._id}')">
      <span class="sel-badge">✓ Selected</span>
      <div style="font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:8px;display:inline-block;margin-bottom:5px;background:${_catColors[loc.category]||'#f3f4f6'};color:${_catText[loc.category]||'#374151'}">${_catEmojis[loc.category]||'📍'} ${loc.category}</div>
      <div style="font-weight:700;font-size:.88rem;color:#1a4a2e;margin-bottom:3px;">${loc.name}</div>
      <div style="font-size:.76rem;color:#6b7280;">${loc.address}</div>
      ${loc.description?`<div style="font-size:.72rem;color:#9ca3af;margin-top:3px;">${loc.description}</div>`:''}
      ${loc.latitude?`<div style="font-size:.7rem;color:#22c55e;margin-top:3px;"><i class="bi bi-crosshair me-1"></i>GPS available</div>`:''}
    </div>`).join('');
}).catch(()=>document.getElementById('needyLoading').style.display='none');

function _selectNeedy(id){
  const loc=_allLocs.find(l=>l._id===id); if(!loc) return;
  document.getElementById('delivLocText').value=loc.name+', '+loc.address;
  document.getElementById('delivLat').value=loc.latitude||'';
  document.getElementById('delivLng').value=loc.longitude||'';
  document.querySelectorAll('.needy-card').forEach(c=>c.classList.remove('selected'));
  document.getElementById('nnc_'+id).classList.add('selected');
  document.getElementById('delivLocText').scrollIntoView({behavior:'smooth',block:'center'});
}

function toggleNeedyMap(){
  const m=document.getElementById('needyMapNGO');
  const hidden=m.style.display==='none'||!m.style.display;
  m.style.display=hidden?'block':'none';
  if(hidden&&!_ngoNeedyInited){
    _ngoNeedyInited=true;
    _ngoNeedyMap=L.map('needyMapNGO').setView([12.9716,77.5946],5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OSM'}).addTo(_ngoNeedyMap);
    const pts=[];
    _allLocs.forEach(loc=>{
      if(!loc.latitude||!loc.longitude) return;
      const icon=L.divIcon({className:'',iconSize:[32,32],iconAnchor:[16,16],html:`<div style="background:${_pinColor[loc.category]||'#6b7280'};width:32px;height:32px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;font-size:14px;">${_catEmojis[loc.category]||'📍'}</div>`});
      L.marker([loc.latitude,loc.longitude],{icon}).addTo(_ngoNeedyMap)
        .bindPopup(`<b>${loc.name}</b><br><small>${loc.address}</small><br><a href="#" onclick="_selectNeedy('${loc._id}');return false;" style="color:#1a4a2e;font-weight:700;">✓ Select</a>`);
      pts.push([loc.latitude,loc.longitude]);
    });
    if(pts.length===1) _ngoNeedyMap.setView(pts[0],14);
    else if(pts.length>1) _ngoNeedyMap.fitBounds(L.latLngBounds(pts),{padding:[30,30]});
    setTimeout(()=>_ngoNeedyMap.invalidateSize(),200);
  } else if(hidden) { setTimeout(()=>_ngoNeedyMap.invalidateSize(),100); }
}
</script>

<%- include('../partials/footer') %>
