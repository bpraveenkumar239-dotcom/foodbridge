<%- include('../partials/header', {title: 'Set Delivery – FoodBridge'}) %>
<%- include('../partials/navbar') %>

<div class="page-section">
  <div class="container" style="padding-top:20px;padding-bottom:40px;">

    <a href="/ngo/requests" class="back-link mb-3 d-inline-flex"><i class="bi bi-arrow-left me-2"></i>Back</a>

    <% const isOverride = !!(food.deliveryLocation); %>

    <h2 class="section-title">
      <%= isOverride ? '🔄 Change Delivery Location' : '📍 Set Delivery Location' %>
    </h2>
    <p class="section-subtitle mb-4">
      <% if (isOverride) { %>
        Donor set a delivery location — you can change it. Pick a needy location or enter your own.
      <% } else { %>
        Donor didn't set a delivery location. Pick from admin-suggested needy locations or enter your own.
      <% } %>
    </p>

    <!-- Donation summary -->
    <div class="donation-summary-card mb-4">
      <div class="d-flex align-items-start gap-3">
        <span style="font-size:1.8rem;flex-shrink:0;">🍱</span>
        <div style="min-width:0;flex:1;">
          <h5 class="mb-1" style="font-size:.95rem;word-break:break-word;"><%= food.name %> — <strong><%= food.quantity %></strong></h5>
          <div class="text-muted" style="font-size:.78rem;"><i class="bi bi-person me-1"></i><%= food.donorName %>
            <% if (food.donorPhone) { %>
              &nbsp;·&nbsp;<a href="tel:<%= food.donorPhone %>" class="donor-phone-link"><i class="bi bi-telephone-fill me-1"></i><%= food.donorPhone %></a>
            <% } %>
          </div>
          <div class="text-muted" style="font-size:.78rem;word-break:break-all;"><i class="bi bi-geo-alt me-1"></i><%= food.pickupLocation %></div>

          <% if (food.deliveryLocation) { %>
            <div style="margin-top:6px;background:#fef9c3;border:1.5px solid #fde68a;border-radius:8px;padding:7px 10px;font-size:.78rem;color:#92400e;">
              <i class="bi bi-send-check me-1"></i><strong>Donor's delivery:</strong> <%= food.deliveryLocation %>
            </div>
          <% } %>
          <% if (food.ngoDeliveryLocation) { %>
            <div style="margin-top:6px;background:#eff6ff;border:1.5px solid #bfdbfe;border-radius:8px;padding:7px 10px;font-size:.78rem;color:#1e40af;">
              <i class="bi bi-pin-map-fill me-1"></i><strong>Current (you set):</strong> <%= food.ngoDeliveryLocation %>
            </div>
          <% } %>
        </div>
        <span class="status-badge status-<%= food.status %>" style="flex-shrink:0;"><%= food.status.replace('_',' ').toUpperCase() %></span>
      </div>
    </div>

    <!-- ═══════ NEEDY LOCATIONS PANEL ═══════ -->
    <div class="needy-panel-header">
      <h5 class="needy-panel-title">
        <i class="bi bi-heart-fill text-danger"></i>
        Admin Suggested Locations
        <span class="needy-count-badge" id="needyCount" style="display:none;"></span>
      </h5>
      <button type="button" class="needy-map-btn" id="mapToggleBtn" onclick="toggleNeedyMap()" style="display:none;">
        <i class="bi bi-map me-1"></i><span id="mapBtnText">Map View</span>
      </button>
    </div>

    <div id="needyLoading" class="text-center py-3" style="color:#9ca3af;">
      <div class="spinner-border spinner-border-sm text-success me-2"></div>Loading locations…
    </div>
    <div id="needyEmpty" style="display:none;" class="text-center py-2">
      <p style="color:#9ca3af;font-size:.85rem;">No needy locations added by admin yet.</p>
    </div>

    <!-- Selected bar -->
    <div class="selected-location-bar" id="selectedBar">
      <i class="bi bi-check-circle-fill text-success fs-5 flex-shrink-0"></i>
      <div style="min-width:0;flex:1;">
        <div style="font-size:.7rem;text-transform:uppercase;letter-spacing:.5px;color:#065f46;margin-bottom:2px;">Selected</div>
        <div id="selectedBarText" style="font-size:.85rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
      </div>
      <button type="button" onclick="clearNeedy()" style="background:none;border:none;color:#991b1b;font-size:1.1rem;cursor:pointer;flex-shrink:0;">
        <i class="bi bi-x-circle"></i>
      </button>
    </div>

    <!-- Cards -->
    <div id="needyGrid" style="display:none;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;margin-bottom:14px;"></div>

    <!-- Map -->
    <div id="needyMapWrap" style="display:none;margin-bottom:14px;">
      <div id="needyMap" style="height:260px;border-radius:14px;border:2px solid #e5e7eb;"></div>
      <p style="font-size:.74rem;color:#6b7280;margin-top:5px;text-align:center;"><i class="bi bi-cursor me-1"></i>Tap a pin to select</p>
    </div>

    <!-- Divider -->
    <div class="needy-divider">
      <div class="needy-divider-line"></div>
      <span class="needy-divider-text">OR ENTER MANUALLY</span>
      <div class="needy-divider-line"></div>
    </div>

    <!-- ═══════ MANUAL FORM ═══════ -->
    <div class="form-card">
      <form action="/ngo/set-delivery/<%= food._id %>" method="POST" id="setDelivForm">
        <input type="hidden" name="ngoDeliveryLocation"  id="finalLocation" value="<%= food.ngoDeliveryLocation || '' %>"/>
        <input type="hidden" name="ngoDeliveryLatitude"  id="finalLat"      value="<%= food.ngoDeliveryLatitude  || '' %>"/>
        <input type="hidden" name="ngoDeliveryLongitude" id="finalLng"      value="<%= food.ngoDeliveryLongitude || '' %>"/>

        <% if (isOverride) { %>
        <div class="mb-3">
          <label class="form-label" style="font-size:.82rem;">Reason for change <span class="text-muted">(optional, shared with donor)</span></label>
          <input type="text" name="ngoOverrideNote" class="fc-custom"
            value="<%= food.ngoOverrideNote || '' %>"
            placeholder="e.g. Closer to shelter, road blocked…"/>
        </div>
        <% } else { %>
          <input type="hidden" name="ngoOverrideNote" value=""/>
        <% } %>

        <label class="form-label">Delivery Address</label>
        <div class="location-selector mb-3">
          <div class="location-tabs">
            <button type="button" class="loc-tab active" data-method="manual"><i class="bi bi-keyboard me-1"></i>Type</button>
            <button type="button" class="loc-tab" data-method="live"><i class="bi bi-geo-alt-fill me-1"></i>GPS</button>
            <button type="button" class="loc-tab" data-method="map"><i class="bi bi-map me-1"></i>Map</button>
          </div>
          <div class="location-input-area">
            <input type="text" class="fc-custom" id="delivLocText"
              placeholder="Enter delivery address…"
              value="<%= food.ngoDeliveryLocation || '' %>"
              oninput="onManualType()" style="width:100%;"/>
            <div id="liveStatus" class="location-status mt-2" style="display:none;">
              <div class="spinner-border spinner-border-sm text-success me-2"></div>Detecting…
            </div>
            <div id="delivMapWrap" style="display:none;margin-top:10px;">
              <div id="delivMap" style="height:260px;border-radius:12px;"></div>
              <p class="map-hint"><i class="bi bi-cursor me-1"></i>Tap to pick delivery point</p>
            </div>
          </div>
        </div>

        <div class="d-flex flex-column gap-2">
          <button type="submit" class="btn btn-primary btn-submit" id="saveBtn">
            <i class="bi bi-check2-circle me-2"></i>Save Delivery Location
          </button>
          <a href="/ngo/navigate/<%= food._id %>" class="btn btn-ghost text-center">
            Skip & Navigate
          </a>
        </div>
      </form>
    </div>

  </div>
</div>

<script>
let allLocs = [], selLocId = null;
let needyMapObj = null, needyMapInited = false;
let delivMapObj = null, delivMarker = null;

const catEmojis = {orphanage:'🏠',shelter:'🏕️',oldage:'👴',school:'🏫',hospital:'🏥',community:'🤝',station:'🚉',other:'📍'};
const catColors  = {orphanage:'#dbeafe',shelter:'#dcfce7',oldage:'#fef3c7',school:'#ede9fe',hospital:'#fee2e2',community:'#e0f2fe',station:'#fdf4ff',other:'#f3f4f6'};
const catText    = {orphanage:'#1e40af',shelter:'#065f46',oldage:'#92400e',school:'#5b21b6',hospital:'#991b1b',community:'#0369a1',station:'#7e22ce',other:'#374151'};
const pinColor   = {orphanage:'#3b82f6',shelter:'#22c55e',oldage:'#f59e0b',school:'#8b5cf6',hospital:'#ef4444',community:'#06b6d4',station:'#a855f7',other:'#6b7280'};

// Fetch needy locations
fetch('/api/needy-locations')
  .then(r => r.json())
  .then(data => {
    document.getElementById('needyLoading').style.display = 'none';
    if (!data.success || !data.locations || !data.locations.length) {
      document.getElementById('needyEmpty').style.display = 'block';
      return;
    }
    allLocs = data.locations;
    document.getElementById('needyCount').textContent = data.locations.length + ' places';
    document.getElementById('needyCount').style.display = 'inline';
    document.getElementById('mapToggleBtn').style.display = 'inline-flex';
    renderCards();
    document.getElementById('needyGrid').style.display = 'grid';
  })
  .catch(() => { document.getElementById('needyLoading').style.display = 'none'; });

function renderCards() {
  const g = document.getElementById('needyGrid');
  g.innerHTML = allLocs.map(loc => `
    <div class="needy-card" id="nc_${loc._id}" onclick="selectNeedy('${loc._id}')">
      <span class="sel-badge">✓ Selected</span>
      <span style="background:${catColors[loc.category]||'#f3f4f6'};color:${catText[loc.category]||'#374151'};font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:8px;display:inline-block;margin-bottom:6px;">
        ${catEmojis[loc.category]||'📍'} ${(loc.category||'other').replace('_',' ')}
      </span>
      <div style="font-weight:700;font-size:.9rem;color:#1a4a2e;margin-bottom:3px;">${loc.name}</div>
      <div style="font-size:.78rem;color:#6b7280;">${loc.address}</div>
      ${loc.description ? `<div style="font-size:.72rem;color:#9ca3af;margin-top:3px;">${loc.description}</div>` : ''}
      ${loc.contactPhone ? `<div style="font-size:.72rem;color:#1a4a2e;margin-top:4px;"><i class="bi bi-telephone me-1"></i>${loc.contactPhone}</div>` : ''}
      ${loc.latitude ? `<div style="font-size:.68rem;color:#22c55e;margin-top:4px;"><i class="bi bi-crosshair me-1"></i>GPS available</div>` : ''}
    </div>`).join('');
}

function selectNeedy(id) {
  const loc = allLocs.find(l => l._id === id);
  if (!loc) return;
  selLocId = id;
  const address = loc.name + ', ' + loc.address;
  document.getElementById('finalLocation').value = address;
  document.getElementById('finalLat').value = loc.latitude  || '';
  document.getElementById('finalLng').value = loc.longitude || '';
  document.getElementById('delivLocText').value = '';
  document.querySelectorAll('.needy-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('nc_' + id).classList.add('selected');
  document.getElementById('selectedBarText').textContent = address;
  document.getElementById('selectedBar').classList.add('show');
  document.getElementById('saveBtn').scrollIntoView({ behavior:'smooth', block:'nearest' });
}

function clearNeedy() {
  selLocId = null;
  document.getElementById('finalLocation').value = '';
  document.getElementById('finalLat').value = '';
  document.getElementById('finalLng').value = '';
  document.querySelectorAll('.needy-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('selectedBar').classList.remove('show');
}

function toggleNeedyMap() {
  const wrap = document.getElementById('needyMapWrap');
  const open = wrap.style.display === 'block';
  wrap.style.display = open ? 'none' : 'block';
  document.getElementById('mapBtnText').textContent = open ? 'Map View' : 'List View';
  if (!open && !needyMapInited) {
    needyMapInited = true;
    needyMapObj = L.map('needyMap').setView([12.9716, 77.5946], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution:'© OpenStreetMap' }).addTo(needyMapObj);
    const pts = [];
    allLocs.forEach(loc => {
      if (!loc.latitude || !loc.longitude) return;
      const icon = L.divIcon({ className:'', iconSize:[32,32], iconAnchor:[16,16],
        html:`<div style="background:${pinColor[loc.category]||'#6b7280'};width:32px;height:32px;border-radius:50%;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;font-size:13px;">${catEmojis[loc.category]||'📍'}</div>` });
      L.marker([loc.latitude, loc.longitude], { icon }).addTo(needyMapObj)
        .bindPopup(`<b>${loc.name}</b><br><small>${loc.address}</small><br><button onclick="selectNeedy('${loc._id}')" style="margin-top:5px;background:#1a4a2e;color:#fff;border:none;border-radius:7px;padding:5px 12px;font-size:.78rem;cursor:pointer;">✓ Select</button>`);
      pts.push([loc.latitude, loc.longitude]);
    });
    if (pts.length === 1) needyMapObj.setView(pts[0], 14);
    else if (pts.length > 1) needyMapObj.fitBounds(L.latLngBounds(pts), { padding:[30,30] });
    setTimeout(() => needyMapObj.invalidateSize(), 200);
  } else if (!open) { setTimeout(() => needyMapObj.invalidateSize(), 100); }
}

function onManualType() {
  selLocId = null;
  document.querySelectorAll('.needy-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('selectedBar').classList.remove('show');
  const v = document.getElementById('delivLocText').value.trim();
  document.getElementById('finalLocation').value = v;
  document.getElementById('finalLat').value = '';
  document.getElementById('finalLng').value = '';
}

document.getElementById('setDelivForm').addEventListener('submit', function(e) {
  const manual = document.getElementById('delivLocText').value.trim();
  if (!selLocId && manual) document.getElementById('finalLocation').value = manual;
  if (!document.getElementById('finalLocation').value.trim()) {
    e.preventDefault(); alert('Please select or enter a delivery location.');
  }
});

// Location tabs
document.querySelectorAll('.loc-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.loc-tab').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    const m = this.dataset.method;
    document.getElementById('liveStatus').style.display  = 'none';
    document.getElementById('delivMapWrap').style.display = 'none';
    if (m === 'live') {
      document.getElementById('liveStatus').style.display = 'flex';
      navigator.geolocation.getCurrentPosition(pos => {
        const lat = pos.coords.latitude, lng = pos.coords.longitude;
        document.getElementById('finalLat').value = lat;
        document.getElementById('finalLng').value = lng;
        document.getElementById('liveStatus').style.display = 'none';
        reverseGeocode(lat, lng, v => { document.getElementById('delivLocText').value = v; document.getElementById('finalLocation').value = v; clearNeedy(); });
      }, () => { document.getElementById('liveStatus').innerHTML = '<i class="bi bi-x-circle text-danger me-2"></i>Location denied.'; });
    } else if (m === 'map') {
      document.getElementById('delivMapWrap').style.display = 'block';
      if (!delivMapObj) {
        delivMapObj = L.map('delivMap').setView([12.9716, 77.5946], 10);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution:'© OpenStreetMap' }).addTo(delivMapObj);
        delivMapObj.on('click', e => {
          if (delivMarker) delivMapObj.removeLayer(delivMarker);
          delivMarker = L.marker([e.latlng.lat, e.latlng.lng]).addTo(delivMapObj);
          document.getElementById('finalLat').value = e.latlng.lat;
          document.getElementById('finalLng').value = e.latlng.lng;
          reverseGeocode(e.latlng.lat, e.latlng.lng, v => { document.getElementById('delivLocText').value = v; document.getElementById('finalLocation').value = v; clearNeedy(); });
        });
      } else { setTimeout(() => delivMapObj.invalidateSize(), 100); }
    }
  });
});

function reverseGeocode(lat, lng, cb) {
  fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`)
    .then(r => r.json()).then(d => cb(d.display_name || `${lat.toFixed(4)}, ${lng.toFixed(4)}`))
    .catch(() => cb(`${lat.toFixed(4)}, ${lng.toFixed(4)}`));
}
</script>

<%- include('../partials/suggest-location-modal', { role: 'ngo' }) %>
<%- include('../partials/footer') %>
