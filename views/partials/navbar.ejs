<nav class="navbar navbar-expand-lg navbar-custom">
  <div class="container-fluid px-4">
    <a class="navbar-brand" href="/">
      <span class="brand-icon">🌿</span>
      <span class="brand-text">FoodBridge</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto align-items-center">
        <% if (user) { %>
          <% if (user.role === 'donor') { %>
            <li class="nav-item"><a class="nav-link" href="/donor/dashboard"><i class="bi bi-house"></i> Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/donor/donate"><i class="bi bi-plus-circle"></i> Donate</a></li>
            <li class="nav-item"><a class="nav-link" href="/donor/history"><i class="bi bi-clock-history"></i> History</a></li>
            <li class="nav-item"><a class="nav-link" href="/donor/impact"><i class="bi bi-heart-pulse"></i> My Impact</a></li>
          <% } else if (user.role === 'ngo') { %>
            <li class="nav-item"><a class="nav-link" href="/ngo/dashboard"><i class="bi bi-house"></i> Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/ngo/requests"><i class="bi bi-list-check"></i> Requests</a></li>
            <li class="nav-item"><a class="nav-link" href="/ngo/map"><i class="bi bi-map"></i> Map View</a></li>
            <li class="nav-item"><a class="nav-link" href="/ngo/leaderboard"><i class="bi bi-trophy"></i> Leaderboard</a></li>
          <% } else if (user.role === 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Admin</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/users"><i class="bi bi-people"></i> Users</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/donations"><i class="bi bi-box-seam"></i> Donations</a></li>
          <% } %>

          <!-- Notification Bell (not for admin) -->
          <% if (user.role !== 'admin') { %>
          <li class="nav-item" style="position:relative;">
            <button class="nav-link" id="notifBell" onclick="toggleNotifPanel()" style="background:none;border:none;cursor:pointer;position:relative;padding:8px 14px;">
              <i class="bi bi-bell" style="font-size:1.1rem;"></i>
              <span id="notifBadge" style="display:none;position:absolute;top:4px;right:8px;background:#ef4444;color:#fff;border-radius:50%;width:16px;height:16px;font-size:.62rem;font-weight:700;display:flex;align-items:center;justify-content:center;"></span>
            </button>
            <!-- Notification dropdown -->
            <div id="notifPanel" style="display:none;position:absolute;right:0;top:48px;width:340px;background:#fff;border-radius:14px;box-shadow:0 8px 40px rgba(0,0,0,.18);z-index:999;overflow:hidden;">
              <div style="padding:14px 16px;border-bottom:1px solid #f3f4f6;display:flex;justify-content:space-between;align-items:center;">
                <strong style="font-size:.9rem;">Notifications</strong>
                <button onclick="markAllRead()" style="background:none;border:none;font-size:.75rem;color:#22c55e;cursor:pointer;font-weight:600;">Mark all read</button>
              </div>
              <div id="notifList" style="max-height:320px;overflow-y:auto;font-size:.82rem;">
                <div style="padding:24px;text-align:center;color:#9ca3af;">Loading…</div>
              </div>
            </div>
          </li>
          <% } %>

          <li class="nav-item">
            <span class="nav-user-badge">
              <%= user.name || user.email %> ·
              <span class="role-tag" style="<%= user.role==='admin'?'background:#7c3aed;':'' %>"><%= user.role.toUpperCase() %></span>
            </span>
          </li>
          <li class="nav-item"><a class="nav-link nav-logout" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
          <li class="nav-item"><a class="nav-link nav-cta" href="/register">Register</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<% if (user && user.role !== 'admin') { %>
<script>
let notifOpen = false;

function toggleNotifPanel() {
  notifOpen = !notifOpen;
  const panel = document.getElementById('notifPanel');
  panel.style.display = notifOpen ? 'block' : 'none';
  if (notifOpen) loadNotifications();
}

document.addEventListener('click', e => {
  const bell  = document.getElementById('notifBell');
  const panel = document.getElementById('notifPanel');
  if (panel && !bell.contains(e.target) && !panel.contains(e.target)) {
    panel.style.display = 'none'; notifOpen = false;
  }
});

const typeIcons = { accepted:'✅', rejected:'❌', picked_up:'🚚', delivered:'🎉', note:'💬', rating:'⭐', expiry:'⏰', system:'📢' };
const typeColors = { accepted:'#dcfce7', rejected:'#fee2e2', picked_up:'#dbeafe', delivered:'#ede9fe', note:'#fef3c7', rating:'#fef9c3', expiry:'#ffedd5', system:'#f3f4f6' };

async function loadNotifications() {
  try {
    const r = await fetch('/api/notifications');
    const d = await r.json();
    const list = document.getElementById('notifList');
    if (!d.notifications || d.notifications.length === 0) {
      list.innerHTML = '<div style="padding:24px;text-align:center;color:#9ca3af;">No notifications yet</div>';
      return;
    }
    list.innerHTML = d.notifications.map(n => `
      <div style="padding:12px 16px;border-bottom:1px solid #f9fafb;background:${n.isRead?'#fff':typeColors[n.type]||'#f9fafb'};cursor:pointer;"
           onclick="openNotif('${n._id}','${n.foodId||''}')">
        <div style="display:flex;gap:8px;align-items:flex-start;">
          <span style="font-size:1rem;flex-shrink:0;">${typeIcons[n.type]||'📢'}</span>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:${n.isRead?'500':'700'};color:#1a4a2e;">${n.title}</div>
            <div style="color:#6b7280;font-size:.78rem;margin-top:2px;line-height:1.4;">${n.message}</div>
            <div style="color:#d1d5db;font-size:.7rem;margin-top:4px;">${timeAgo(n.createdAt)}</div>
          </div>
          ${!n.isRead ? '<span style="width:8px;height:8px;border-radius:50%;background:#22c55e;flex-shrink:0;margin-top:4px;"></span>' : ''}
        </div>
      </div>`).join('');
  } catch(e) {}
}

async function markAllRead() {
  await fetch('/api/notifications/read', { method:'POST' });
  document.getElementById('notifBadge').style.display = 'none';
  loadNotifications();
}

async function openNotif(id, foodId) {
  await fetch('/api/notifications/'+id+'/read', { method:'POST' });
  if (foodId) window.location.href = '<%= user && user.role === "donor" ? "/donor/track/" : "/ngo/navigate/" %>' + foodId;
}

function timeAgo(dateStr) {
  const d = Math.floor((Date.now() - new Date(dateStr)) / 1000);
  if (d < 60)   return 'just now';
  if (d < 3600) return Math.floor(d/60)+'m ago';
  if (d < 86400) return Math.floor(d/3600)+'h ago';
  return Math.floor(d/86400)+'d ago';
}

// Poll unread count every 30s
async function pollNotifCount() {
  try {
    const r = await fetch('/api/notifications/count');
    const d = await r.json();
    const badge = document.getElementById('notifBadge');
    if (d.count > 0) {
      badge.style.display = 'flex'; badge.textContent = d.count > 9 ? '9+' : d.count;
    } else {
      badge.style.display = 'none';
    }
  } catch(e) {}
}
pollNotifCount();
setInterval(pollNotifCount, 30000);
</script>
<% } %>
