<!-- ══════════════════════════════════════════════════
     Suggest Needy Location Modal
     Usage: include with role='donor' or role='ngo'
     ══════════════════════════════════════════════════ -->

<!-- Floating Suggest Button -->
<button id="suggestLocBtn" onclick="openSuggestModal()" style="
  position:fixed;bottom:84px;right:18px;z-index:1200;
  background:linear-gradient(135deg,#1a4a2e,#2d7a4f);
  color:#fff;border:none;border-radius:50px;
  padding:12px 18px;font-family:'DM Sans',sans-serif;
  font-weight:700;font-size:.82rem;cursor:pointer;
  box-shadow:0 4px 18px rgba(26,74,46,.4);
  display:flex;align-items:center;gap:8px;
  transition:transform .2s,box-shadow .2s;
" onmouseenter="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(26,74,46,.5)'"
   onmouseleave="this.style.transform='';this.style.boxShadow='0 4px 18px rgba(26,74,46,.4)'">
  <i class="bi bi-geo-alt-fill"></i> Suggest Location
</button>

<!-- Modal Backdrop -->
<div id="suggestModalBackdrop" onclick="closeSuggestModal()" style="
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);
  z-index:1300;backdrop-filter:blur(2px);
"></div>

<!-- Modal -->
<div id="suggestModal" style="
  display:none;position:fixed;bottom:0;left:0;right:0;
  z-index:1400;background:#fff;
  border-radius:24px 24px 0 0;
  padding:24px 20px 36px;
  max-height:90vh;overflow-y:auto;
  box-shadow:0 -8px 40px rgba(0,0,0,.2);
  font-family:'DM Sans',sans-serif;
  transform:translateY(100%);transition:transform .3s ease;
">
  <!-- Handle -->
  <div style="width:40px;height:4px;background:#e5e7eb;border-radius:4px;margin:0 auto 20px;"></div>

  <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;">
    <div style="background:#e8f5ee;border-radius:12px;width:44px;height:44px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">📍</div>
    <div>
      <h5 style="margin:0;font-weight:700;color:#1a4a2e;font-size:1rem;">Suggest a Needy Location</h5>
      <p style="margin:0;font-size:.75rem;color:#6b7280;">Admin will review and approve your suggestion</p>
    </div>
  </div>

  <!-- Success message -->
  <div id="suggestSuccess" style="display:none;background:#f0fdf4;border:2px solid #4ade80;border-radius:14px;padding:18px;text-align:center;margin-bottom:14px;">
    <div style="font-size:2rem;margin-bottom:6px;">🎉</div>
    <div style="font-weight:700;color:#14532d;font-size:.95rem;">Suggestion Submitted!</div>
    <div style="color:#166534;font-size:.8rem;margin-top:4px;">Admin will review it shortly. Thank you!</div>
  </div>

  <form id="suggestForm" onsubmit="submitSuggestion(event)">
    <!-- Name -->
    <div style="margin-bottom:14px;">
      <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Location Name *</label>
      <input type="text" id="sug_name" required placeholder="e.g. Sunrise Orphanage"
        style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;box-sizing:border-box;"
        onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"/>
    </div>

    <!-- Category -->
    <div style="margin-bottom:14px;">
      <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Category</label>
      <select id="sug_category" style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;background:#fff;box-sizing:border-box;"
        onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'">
        <option value="orphanage">🏠 Orphanage</option>
        <option value="shelter">🏕️ Shelter</option>
        <option value="oldage">👴 Old Age Home</option>
        <option value="school">🏫 School</option>
        <option value="hospital">🏥 Hospital</option>
        <option value="community">🤝 Community Centre</option>
        <option value="station">🚉 Railway Station</option>
        <option value="other" selected>📍 Other</option>
      </select>
    </div>

    <!-- Address -->
    <div style="margin-bottom:14px;">
      <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Address *</label>
      <input type="text" id="sug_address" required placeholder="Full address"
        style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;box-sizing:border-box;"
        onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"/>
    </div>

    <!-- Description -->
    <div style="margin-bottom:14px;">
      <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Who is served here? <span style="color:#9ca3af;font-weight:400;">(optional)</span></label>
      <textarea id="sug_description" rows="2" placeholder="e.g. Approximately 80 children aged 5–16"
        style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;resize:none;box-sizing:border-box;"
        onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"></textarea>
    </div>

    <!-- Contact -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">
      <div>
        <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Contact Name <span style="color:#9ca3af;font-weight:400;">(opt.)</span></label>
        <input type="text" id="sug_contactName" placeholder="Person to contact"
          style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;box-sizing:border-box;"
          onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"/>
      </div>
      <div>
        <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Phone <span style="color:#9ca3af;font-weight:400;">(opt.)</span></label>
        <input type="tel" id="sug_contactPhone" placeholder="+91 99999 00000"
          style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;box-sizing:border-box;"
          onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"/>
      </div>
    </div>

    <!-- GPS (auto-detect) -->
    <div style="margin-bottom:20px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <button type="button" onclick="detectGPS()" id="gpsBtn" style="
          background:#e8f5ee;border:2px solid #bbf7d0;color:#1a4a2e;border-radius:10px;
          padding:9px 14px;font-family:'DM Sans',sans-serif;font-weight:600;
          font-size:.8rem;cursor:pointer;display:flex;align-items:center;gap:6px;flex-shrink:0;
        "><i class="bi bi-geo-alt-fill"></i>Use GPS</button>
        <span id="gpsStatus" style="font-size:.78rem;color:#6b7280;"></span>
      </div>
      <input type="hidden" id="sug_lat"/>
      <input type="hidden" id="sug_lng"/>
    </div>

    <!-- Error msg -->
    <div id="suggestError" style="display:none;background:#fee2e2;color:#991b1b;border-radius:10px;padding:10px 14px;font-size:.82rem;margin-bottom:14px;"></div>

    <!-- Actions -->
    <div style="display:flex;gap:10px;">
      <button type="button" onclick="closeSuggestModal()" style="
        flex:1;background:#f3f4f6;color:#374151;border:none;border-radius:12px;
        padding:13px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.9rem;cursor:pointer;
      ">Cancel</button>
      <button type="submit" id="suggestSubmitBtn" style="
        flex:2;background:linear-gradient(135deg,#1a4a2e,#2d7a4f);color:#fff;border:none;
        border-radius:12px;padding:13px;font-family:'DM Sans',sans-serif;font-weight:700;
        font-size:.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;
      "><i class="bi bi-send-fill"></i>Submit Suggestion</button>
    </div>
  </form>
</div>

<script>
const SUGGEST_ENDPOINT = '<%= role === "donor" ? "/donor/suggest-location" : "/ngo/suggest-location" %>';

function openSuggestModal() {
  document.getElementById('suggestModalBackdrop').style.display = 'block';
  const m = document.getElementById('suggestModal');
  m.style.display = 'block';
  setTimeout(() => m.style.transform = 'translateY(0)', 10);
  document.getElementById('suggestSuccess').style.display = 'none';
  document.getElementById('suggestForm').style.display = 'block';
  document.getElementById('suggestError').style.display = 'none';
}

function closeSuggestModal() {
  const m = document.getElementById('suggestModal');
  m.style.transform = 'translateY(100%)';
  setTimeout(() => {
    m.style.display = 'none';
    document.getElementById('suggestModalBackdrop').style.display = 'none';
  }, 300);
}

function detectGPS() {
  const btn = document.getElementById('gpsBtn');
  const status = document.getElementById('gpsStatus');
  btn.innerHTML = '<div style="width:14px;height:14px;border:2px solid #1a4a2e;border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;"></div> Detecting…';
  navigator.geolocation.getCurrentPosition(pos => {
    document.getElementById('sug_lat').value = pos.coords.latitude;
    document.getElementById('sug_lng').value = pos.coords.longitude;
    btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> GPS Set';
    btn.style.background = '#dcfce7'; btn.style.borderColor = '#4ade80';
    status.textContent = pos.coords.latitude.toFixed(4) + ', ' + pos.coords.longitude.toFixed(4);
    status.style.color = '#166534';
    // Reverse geocode and fill address if empty
    if (!document.getElementById('sug_address').value) {
      fetch(`https://nominatim.openstreetmap.org/reverse?lat=${pos.coords.latitude}&lon=${pos.coords.longitude}&format=json`)
        .then(r => r.json()).then(d => {
          if (d.display_name) document.getElementById('sug_address').value = d.display_name;
        }).catch(() => {});
    }
  }, () => {
    btn.innerHTML = '<i class="bi bi-geo-alt-fill"></i>Use GPS';
    status.textContent = 'Location denied'; status.style.color = '#991b1b';
  });
}

async function submitSuggestion(e) {
  e.preventDefault();
  const btn = document.getElementById('suggestSubmitBtn');
  const errEl = document.getElementById('suggestError');
  errEl.style.display = 'none';
  btn.innerHTML = '<div style="width:16px;height:16px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;"></div> Submitting…';
  btn.disabled = true;

  const body = {
    name:         document.getElementById('sug_name').value.trim(),
    address:      document.getElementById('sug_address').value.trim(),
    category:     document.getElementById('sug_category').value,
    description:  document.getElementById('sug_description').value.trim(),
    contactName:  document.getElementById('sug_contactName').value.trim(),
    contactPhone: document.getElementById('sug_contactPhone').value.trim(),
    latitude:     document.getElementById('sug_lat').value,
    longitude:    document.getElementById('sug_lng').value,
  };

  try {
    const res = await fetch(SUGGEST_ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if (data.success) {
      document.getElementById('suggestForm').style.display = 'none';
      document.getElementById('suggestSuccess').style.display = 'block';
      setTimeout(closeSuggestModal, 3000);
    } else {
      errEl.textContent = data.message || 'Something went wrong.';
      errEl.style.display = 'block';
    }
  } catch (err) {
    errEl.textContent = 'Network error. Please try again.';
    errEl.style.display = 'block';
  }
  btn.innerHTML = '<i class="bi bi-send-fill"></i>Submit Suggestion';
  btn.disabled = false;
}

// Add spin keyframe if not present
if (!document.getElementById('suggestSpinStyle')) {
  const s = document.createElement('style');
  s.id = 'suggestSpinStyle';
  s.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
  document.head.appendChild(s);
}
</script>
