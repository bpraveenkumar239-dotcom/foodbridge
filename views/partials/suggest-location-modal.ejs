<!-- Suggest Needy Location Modal - included before footer -->
<!-- Role is passed via data attribute to avoid EJS inside JS strings -->
<div data-suggest-role="<%= role %>"></div>

<button onclick="openSuggestNeedyModal()" style="position:fixed;bottom:84px;right:18px;z-index:1200;background:linear-gradient(135deg,#1a4a2e,#2d7a4f);color:#fff;border:none;border-radius:50px;padding:12px 20px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.82rem;cursor:pointer;box-shadow:0 4px 18px rgba(26,74,46,.4);display:flex;align-items:center;gap:8px;">
  <i class="bi bi-geo-alt-fill"></i> Suggest Needy Location
</button>

<div id="snBackdrop" onclick="closeSuggestNeedyModal()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:1300;backdrop-filter:blur(2px);"></div>

<div id="snModal" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:1400;background:#fff;border-radius:24px 24px 0 0;max-height:94vh;overflow-y:auto;box-shadow:0 -8px 40px rgba(0,0,0,.22);font-family:'DM Sans',sans-serif;transform:translateY(100%);transition:transform .35s ease;">
  <div style="width:40px;height:4px;background:#d1d5db;border-radius:4px;margin:14px auto 0;"></div>
  <div style="display:flex;align-items:center;gap:12px;padding:18px 20px 0;">
    <div style="background:#e8f5ee;border-radius:14px;width:48px;height:48px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;">&#128205;</div>
    <div style="flex:1;">
      <h5 style="margin:0;font-weight:700;color:#1a4a2e;font-size:1.05rem;">Suggest Needy Location</h5>
      <p style="margin:0;font-size:.75rem;color:#6b7280;">Admin will review and approve your suggestion</p>
    </div>
    <button onclick="closeSuggestNeedyModal()" style="background:none;border:none;font-size:1.4rem;color:#9ca3af;cursor:pointer;padding:4px;line-height:1;">&times;</button>
  </div>

  <div id="snSuccess" style="display:none;padding:36px 20px;text-align:center;">
    <div style="font-size:3rem;margin-bottom:10px;">&#127881;</div>
    <div style="font-weight:700;color:#14532d;font-size:1rem;margin-bottom:6px;">Suggestion Submitted!</div>
    <div style="color:#166534;font-size:.85rem;">Admin will review it shortly. Thank you!</div>
  </div>

  <div id="snFormWrap" style="padding:18px 20px 36px;">
    <!-- Step tabs -->
    <div style="display:flex;margin-bottom:20px;border:2px solid #e5e7eb;border-radius:12px;overflow:hidden;">
      <button type="button" id="snTab1" onclick="snStep(1)" style="flex:1;padding:11px 6px;border:none;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.8rem;cursor:pointer;background:#1a4a2e;color:#fff;">&#9312; Details</button>
      <button type="button" id="snTab2" onclick="snStep(2)" style="flex:1;padding:11px 6px;border:none;border-left:2px solid #e5e7eb;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.8rem;cursor:pointer;background:#f9fafb;color:#6b7280;">&#9313; Pin on Map</button>
    </div>

    <!-- STEP 1 -->
    <div id="snS1">
      <div style="margin-bottom:14px;">
        <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Location Name <span style="color:#ef4444;">*</span></label>
        <input type="text" id="snName" placeholder="e.g. Sunrise Orphanage, City Shelter" style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:12px 14px;font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"/>
      </div>

      <div style="margin-bottom:14px;">
        <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:7px;">Category</label>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;" id="snCatGrid">
          <button type="button" onclick="snCat('orphanage')" id="sc_orphanage" style="border:2px solid #e5e7eb;background:#f9fafb;border-radius:10px;padding:8px 4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:600;color:#374151;display:flex;flex-direction:column;align-items:center;gap:2px;">&#127968;<br>Orphanage</button>
          <button type="button" onclick="snCat('shelter')"   id="sc_shelter"   style="border:2px solid #e5e7eb;background:#f9fafb;border-radius:10px;padding:8px 4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:600;color:#374151;display:flex;flex-direction:column;align-items:center;gap:2px;">&#127957;<br>Shelter</button>
          <button type="button" onclick="snCat('oldage')"    id="sc_oldage"    style="border:2px solid #e5e7eb;background:#f9fafb;border-radius:10px;padding:8px 4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:600;color:#374151;display:flex;flex-direction:column;align-items:center;gap:2px;">&#128116;<br>Old Age</button>
          <button type="button" onclick="snCat('school')"    id="sc_school"    style="border:2px solid #e5e7eb;background:#f9fafb;border-radius:10px;padding:8px 4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:600;color:#374151;display:flex;flex-direction:column;align-items:center;gap:2px;">&#127979;<br>School</button>
          <button type="button" onclick="snCat('hospital')"  id="sc_hospital"  style="border:2px solid #e5e7eb;background:#f9fafb;border-radius:10px;padding:8px 4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:600;color:#374151;display:flex;flex-direction:column;align-items:center;gap:2px;">&#127973;<br>Hospital</button>
          <button type="button" onclick="snCat('community')" id="sc_community" style="border:2px solid #e5e7eb;background:#f9fafb;border-radius:10px;padding:8px 4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:600;color:#374151;display:flex;flex-direction:column;align-items:center;gap:2px;">&#129309;<br>Community</button>
          <button type="button" onclick="snCat('station')"   id="sc_station"   style="border:2px solid #e5e7eb;background:#f9fafb;border-radius:10px;padding:8px 4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:600;color:#374151;display:flex;flex-direction:column;align-items:center;gap:2px;">&#128649;<br>Station</button>
          <button type="button" onclick="snCat('other')"     id="sc_other"     style="border:2px solid #1a4a2e;background:#1a4a2e;border-radius:10px;padding:8px 4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.7rem;font-weight:700;color:#fff;display:flex;flex-direction:column;align-items:center;gap:2px;">&#128205;<br>Other</button>
        </div>
      </div>

      <div style="margin-bottom:14px;">
        <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Who is served here? <span style="color:#9ca3af;font-weight:400;">(optional)</span></label>
        <textarea id="snDesc" rows="2" placeholder="e.g. ~80 children aged 5-16, daily meals needed" style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:12px 14px;font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;resize:none;box-sizing:border-box;" onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"></textarea>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;">
        <div>
          <label style="font-size:.78rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Contact Person <span style="color:#9ca3af;">(opt.)</span></label>
          <input type="text" id="snCName" placeholder="Manager / Warden" style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:11px 12px;font-family:'DM Sans',sans-serif;font-size:.85rem;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"/>
        </div>
        <div>
          <label style="font-size:.78rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Phone <span style="color:#9ca3af;">(opt.)</span></label>
          <input type="tel" id="snPhone" placeholder="+91 98765 43210" style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:11px 12px;font-family:'DM Sans',sans-serif;font-size:.85rem;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"/>
        </div>
      </div>

      <button type="button" onclick="snStep(2)" style="width:100%;background:linear-gradient(135deg,#1a4a2e,#2d7a4f);color:#fff;border:none;border-radius:12px;padding:14px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;">
        Next &mdash; Pin on Map &rarr;
      </button>
    </div>

    <!-- STEP 2 -->
    <div id="snS2" style="display:none;">
      <div style="margin-bottom:12px;">
        <label style="font-size:.8rem;font-weight:700;color:#374151;display:block;margin-bottom:5px;">Address <span style="color:#ef4444;">*</span> <span style="color:#9ca3af;font-weight:400;">- type, use GPS, or tap map</span></label>
        <input type="text" id="snAddr" placeholder="Full address of this needy location" style="width:100%;border:2px solid #e5e7eb;border-radius:10px;padding:12px 14px;font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;box-sizing:border-box;" onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#e5e7eb'"/>
      </div>

      <div style="display:flex;gap:8px;margin-bottom:12px;">
        <button type="button" id="snBtnGPS" onclick="snUseGPS()" style="flex:1;padding:10px 6px;border:2px solid #e5e7eb;border-radius:10px;background:#f9fafb;color:#374151;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.8rem;cursor:pointer;">
          &#128205; Use GPS
        </button>
        <button type="button" id="snBtnMap" onclick="snShowMap()" style="flex:1;padding:10px 6px;border:2px solid #1a4a2e;border-radius:10px;background:#1a4a2e;color:#fff;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.8rem;cursor:pointer;">
          &#128506; Pin on Map
        </button>
      </div>

      <div id="snGPSMsg" style="display:none;margin-bottom:10px;background:#f0fdf4;border-radius:10px;padding:10px 14px;font-size:.82rem;color:#166534;"></div>

      <div id="snMapBox" style="margin-bottom:12px;">
        <div id="snMap" style="height:270px;border-radius:14px;border:2px solid #e5e7eb;background:#f3f4f6;"></div>
        <p style="font-size:.73rem;color:#6b7280;margin-top:5px;text-align:center;">Tap anywhere on the map to pin the needy location</p>
      </div>

      <div id="snPinBar" style="display:none;background:#f0fdf4;border:1.5px solid #4ade80;border-radius:10px;padding:9px 14px;margin-bottom:12px;font-size:.78rem;color:#166534;display:none;align-items:center;gap:8px;">
        <span id="snPinTxt"></span>
        <button type="button" onclick="snClearPin()" style="margin-left:auto;background:none;border:none;color:#991b1b;cursor:pointer;font-size:.82rem;font-weight:600;padding:0;">Clear</button>
      </div>

      <div id="snErrMsg" style="display:none;background:#fee2e2;color:#991b1b;border-radius:10px;padding:10px 14px;font-size:.82rem;margin-bottom:12px;"></div>

      <div style="display:flex;gap:10px;margin-top:6px;">
        <button type="button" onclick="snStep(1)" style="flex:1;background:#f3f4f6;color:#374151;border:none;border-radius:12px;padding:13px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.88rem;cursor:pointer;">&larr; Back</button>
        <button type="button" id="snSubmitBtn" onclick="snSubmit()" style="flex:2;background:linear-gradient(135deg,#1a4a2e,#2d7a4f);color:#fff;border:none;border-radius:12px;padding:13px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.9rem;cursor:pointer;">Submit Suggestion</button>
      </div>
    </div>
  </div>
</div>

<style>
@keyframes snSpin { to { transform: rotate(360deg); } }
.snCatSel { background: #1a4a2e !important; color: #fff !important; border-color: #1a4a2e !important; }
</style>

<script>
(function () {
  var snRole = (document.querySelector('[data-suggest-role]') || {}).dataset.suggestRole || 'donor';
  var snEndpoint = snRole === 'ngo' ? '/ngo/suggest-location' : '/donor/suggest-location';
  var snSelCat = 'other';
  var snLat = null, snLng = null;
  var snMapObj = null, snMapInited = false, snMapMarker = null;

  window.openSuggestNeedyModal = function () {
    document.getElementById('snBackdrop').style.display = 'block';
    var m = document.getElementById('snModal');
    m.style.display = 'block';
    setTimeout(function () { m.style.transform = 'translateY(0)'; }, 10);
    document.getElementById('snSuccess').style.display = 'none';
    document.getElementById('snFormWrap').style.display = 'block';
    document.getElementById('snErrMsg').style.display = 'none';
    snStep(1);
    snCat('other');
  };

  window.closeSuggestNeedyModal = function () {
    var m = document.getElementById('snModal');
    m.style.transform = 'translateY(100%)';
    setTimeout(function () {
      m.style.display = 'none';
      document.getElementById('snBackdrop').style.display = 'none';
    }, 360);
  };

  window.snStep = function (n) {
    document.getElementById('snS1').style.display = n === 1 ? 'block' : 'none';
    document.getElementById('snS2').style.display = n === 2 ? 'block' : 'none';
    var t1 = document.getElementById('snTab1'), t2 = document.getElementById('snTab2');
    if (n === 1) {
      t1.style.background = '#1a4a2e'; t1.style.color = '#fff';
      t2.style.background = '#f9fafb'; t2.style.color = '#6b7280';
    } else {
      t2.style.background = '#1a4a2e'; t2.style.color = '#fff';
      t1.style.background = '#f9fafb'; t1.style.color = '#6b7280';
      setTimeout(snInitMap, 100);
    }
  };

  window.snCat = function (val) {
    snSelCat = val;
    var btns = document.querySelectorAll('[id^="sc_"]');
    for (var i = 0; i < btns.length; i++) {
      var b = btns[i];
      var sel = b.id === 'sc_' + val;
      b.style.background   = sel ? '#1a4a2e' : '#f9fafb';
      b.style.color        = sel ? '#fff'    : '#374151';
      b.style.borderColor  = sel ? '#1a4a2e' : '#e5e7eb';
      b.style.fontWeight   = sel ? '700'     : '600';
    }
  };

  window.snUseGPS = function () {
    var msg = document.getElementById('snGPSMsg');
    msg.style.display = 'block';
    msg.style.background = '#f0fdf4';
    msg.style.color = '#166534';
    msg.textContent = 'Detecting location...';
    navigator.geolocation.getCurrentPosition(
      function (pos) {
        snSetPin(pos.coords.latitude, pos.coords.longitude);
        msg.textContent = 'Location detected!';
        setTimeout(function () { msg.style.display = 'none'; }, 2000);
      },
      function () {
        msg.style.background = '#fee2e2';
        msg.style.color = '#991b1b';
        msg.textContent = 'Location access denied. Please tap the map instead.';
      }
    );
  };

  window.snShowMap = function () {
    document.getElementById('snMapBox').style.display = 'block';
    setTimeout(snInitMap, 100);
    var gBtn = document.getElementById('snBtnGPS'), mBtn = document.getElementById('snBtnMap');
    mBtn.style.background = '#1a4a2e'; mBtn.style.color = '#fff'; mBtn.style.borderColor = '#1a4a2e';
    gBtn.style.background = '#f9fafb'; gBtn.style.color = '#374151'; gBtn.style.borderColor = '#e5e7eb';
  };

  function snInitMap() {
    if (snMapInited) { if (snMapObj) { snMapObj.invalidateSize(); } return; }
    if (typeof L === 'undefined') {
      var s = document.createElement('script');
      s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      s.onload = snInitMap;
      document.head.appendChild(s);
      return;
    }
    snMapInited = true;
    snMapObj = L.map('snMap').setView([20.5937, 78.9629], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap' }).addTo(snMapObj);
    snMapObj.on('click', function (e) { snSetPin(e.latlng.lat, e.latlng.lng); });
    setTimeout(function () { snMapObj.invalidateSize(); }, 200);
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(function (p) {
        snMapObj.setView([p.coords.latitude, p.coords.longitude], 13);
      }, function () {});
    }
  }

  window.snSetPin = function (lat, lng) {
    snLat = lat; snLng = lng;
    if (snMapInited && snMapObj) {
      if (snMapMarker) { snMapObj.removeLayer(snMapMarker); }
      snMapMarker = L.marker([lat, lng], {
        icon: L.divIcon({
          className: '',
          iconSize: [32, 32], iconAnchor: [16, 32],
          html: '<div style="background:#1a4a2e;width:32px;height:32px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid #fff;box-shadow:0 3px 10px rgba(0,0,0,.35);"></div>'
        })
      }).addTo(snMapObj);
      snMapObj.setView([lat, lng], Math.max(snMapObj.getZoom(), 15));
    }
    var bar = document.getElementById('snPinBar');
    document.getElementById('snPinTxt').textContent = lat.toFixed(5) + ', ' + lng.toFixed(5) + ' - pinned';
    bar.style.display = 'flex';
    fetch('https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lng + '&format=json')
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var a = document.getElementById('snAddr');
        if (!a.value && d.display_name) { a.value = d.display_name; }
      })
      .catch(function () {});
  };

  window.snClearPin = function () {
    snLat = null; snLng = null;
    document.getElementById('snPinBar').style.display = 'none';
    if (snMapMarker && snMapObj) { snMapObj.removeLayer(snMapMarker); snMapMarker = null; }
  };

  window.snSubmit = function () {
    var errEl = document.getElementById('snErrMsg');
    errEl.style.display = 'none';
    var name = document.getElementById('snName').value.trim();
    var addr = document.getElementById('snAddr').value.trim();
    if (!name) { snStep(1); errEl.textContent = 'Please enter a location name.'; errEl.style.display = 'block'; return; }
    if (!addr) { errEl.textContent = 'Please enter an address or pin on the map.'; errEl.style.display = 'block'; return; }

    var btn = document.getElementById('snSubmitBtn');
    btn.textContent = 'Submitting...';
    btn.disabled = true;

    var payload = {
      name: name,
      address: addr,
      category: snSelCat,
      description: document.getElementById('snDesc').value.trim(),
      contactName: document.getElementById('snCName').value.trim(),
      contactPhone: document.getElementById('snPhone').value.trim(),
      latitude: snLat,
      longitude: snLng
    };

    fetch(snEndpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (d.success) {
          document.getElementById('snFormWrap').style.display = 'none';
          document.getElementById('snSuccess').style.display = 'block';
          setTimeout(closeSuggestNeedyModal, 3000);
        } else {
          errEl.textContent = d.message || 'Something went wrong.';
          errEl.style.display = 'block';
        }
        btn.textContent = 'Submit Suggestion';
        btn.disabled = false;
      })
      .catch(function () {
        errEl.textContent = 'Network error. Please try again.';
        errEl.style.display = 'block';
        btn.textContent = 'Submit Suggestion';
        btn.disabled = false;
      });
  };
})();
</script>
