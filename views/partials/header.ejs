<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"/>
  <meta name="mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title" content="FoodBridge"/>
  <title><%= title || 'FoodBridge – Leftover Food Management' %></title>
  <link rel="manifest" href="/manifest.json"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon.png"/>
  <link rel="icon" type="image/png" sizes="192x192" href="/images/icon-192.png"/>
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png"/>
  <meta name="theme-color" content="#1a4a2e"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<!-- ── App Splash Screen (hides Render cold-start loading page) ── -->
<div id="fb-splash" style="
  position:fixed;inset:0;z-index:99999;
  background:linear-gradient(135deg,#1a4a2e 0%,#2d7a4f 50%,#4caf77 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  transition:opacity .4s ease;
">
  <img src="/images/icon-192.png" style="width:88px;height:88px;border-radius:22px;box-shadow:0 8px 32px rgba(0,0,0,.3);margin-bottom:20px;" alt="FoodBridge"/>
  <div style="font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:700;color:#fff;margin-bottom:6px;">FoodBridge</div>
  <div style="font-family:'DM Sans',sans-serif;font-size:.88rem;color:rgba(255,255,255,.75);margin-bottom:32px;">Connecting hearts through food</div>
  <div style="width:36px;height:36px;border:3px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:fbSpin .8s linear infinite;"></div>
</div>
<style>
@keyframes fbSpin{to{transform:rotate(360deg)}}
</style>
<script>
  // Hide splash once the page is interactive
  (function(){
    function hideSplash(){
      var s=document.getElementById('fb-splash');
      if(!s)return;
      s.style.opacity='0';
      setTimeout(function(){s.remove();},450);
    }
    if(document.readyState==='complete'||document.readyState==='interactive'){
      setTimeout(hideSplash,300);
    } else {
      window.addEventListener('DOMContentLoaded',function(){setTimeout(hideSplash,300);});
    }
    // Failsafe: always remove within 3s
    setTimeout(hideSplash,3000);
  })();
</script>
