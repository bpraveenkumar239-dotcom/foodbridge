<%- include('layout-start', {title: profile.name+' – Admin', pageTitle:'User Detail', currentPage:'users'}) %>

<% // msg passed from route %>
<% if(msg) { %><div class="alert alert-success mb-4"><i class="bi bi-check-circle me-2"></i><%= msg %></div><% } %>

<a href="/admin/users" class="btn-admin-sm btn-info-sm mb-3 d-inline-flex align-items-center gap-1">
  <i class="bi bi-arrow-left"></i> Back to Users
</a>

<div class="row g-4">
  <!-- Profile card -->
  <div class="col-lg-4">
    <div class="admin-card text-center">
      <div style="width:72px;height:72px;border-radius:50%;background:#e8f5ee;display:flex;align-items:center;justify-content:center;font-size:2.5rem;margin:0 auto 14px;">
        <%= profile.role === 'donor' ? '🤝' : '🏥' %>
      </div>
      <h4 style="font-family:'Playfair Display',serif;color:#1a4a2e;"><%= profile.name %></h4>
      <p style="color:#6b7280;font-size:.88rem;"><%= profile.email %></p>
      <div style="display:flex;justify-content:center;gap:8px;margin-bottom:16px;">
        <span class="role-<%= profile.role %>"><%= profile.role.toUpperCase() %></span>
        <% if(profile.isBanned) { %><span class="badge-banned">BANNED</span><% } else { %><span class="badge-active">ACTIVE</span><% } %>
      </div>

      <div style="text-align:left;font-size:.85rem;">
        <% if(profile.phone){ %>
          <div style="padding:8px 0;border-bottom:1px solid #f3f4f6;display:flex;gap:8px;">
            <i class="bi bi-telephone text-success"></i>
            <a href="tel:<%= profile.phone %>" style="color:#1a4a2e;font-weight:600;"><%= profile.phone %></a>
          </div>
        <% } %>
        <% if(profile.organization){ %>
          <div style="padding:8px 0;border-bottom:1px solid #f3f4f6;display:flex;gap:8px;">
            <i class="bi bi-building text-primary"></i><span><%= profile.organization %></span>
          </div>
        <% } %>
        <% if(profile.address){ %>
          <div style="padding:8px 0;border-bottom:1px solid #f3f4f6;display:flex;gap:8px;">
            <i class="bi bi-geo-alt text-warning"></i><span><%= profile.address %></span>
          </div>
        <% } %>
        <div style="padding:8px 0;display:flex;gap:8px;">
          <i class="bi bi-calendar text-muted"></i>
          <span>Joined <%= new Date(profile.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'}) %></span>
        </div>
      </div>

      <!-- Quick actions -->
      <div style="display:flex;flex-direction:column;gap:8px;margin-top:16px;">
        <% if(profile.isBanned) { %>
          <form action="/admin/users/<%= profile._id %>/unban" method="POST">
            <button type="submit" class="btn btn-success w-100" style="border-radius:10px;font-family:'DM Sans',sans-serif;font-weight:600;">
              <i class="bi bi-unlock me-2"></i>Unban User
            </button>
          </form>
        <% } else { %>
          <button class="btn btn-warning w-100" style="border-radius:10px;font-family:'DM Sans',sans-serif;font-weight:600;"
            onclick="document.getElementById('banSection').scrollIntoView({behavior:'smooth'})">
            <i class="bi bi-ban me-2"></i>Ban User
          </button>
        <% } %>
      </div>
    </div>

    <!-- Edit Profile -->
    <div class="admin-card">
      <div class="admin-card-title"><i class="bi bi-pencil"></i>Edit Profile</div>
      <form action="/admin/users/<%= profile._id %>/edit" method="POST">
        <div class="mb-3">
          <label class="form-label fw-bold" style="font-size:.82rem;">Full Name</label>
          <input type="text" name="name" class="form-control" value="<%= profile.name %>" required style="border-radius:10px;border:2px solid #e5e7eb;"/>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold" style="font-size:.82rem;">Phone</label>
          <input type="tel" name="phone" class="form-control" value="<%= profile.phone||'' %>" style="border-radius:10px;border:2px solid #e5e7eb;"/>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold" style="font-size:.82rem;">Organization</label>
          <input type="text" name="organization" class="form-control" value="<%= profile.organization||'' %>" style="border-radius:10px;border:2px solid #e5e7eb;"/>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold" style="font-size:.82rem;">Address</label>
          <input type="text" name="address" class="form-control" value="<%= profile.address||'' %>" style="border-radius:10px;border:2px solid #e5e7eb;"/>
        </div>
        <button type="submit" class="btn btn-primary w-100" style="border-radius:10px;font-family:'DM Sans',sans-serif;font-weight:600;background:#1a4a2e;border:none;">
          Save Changes
        </button>
      </form>
    </div>

    <!-- Reset Password -->
    <div class="admin-card">
      <div class="admin-card-title"><i class="bi bi-key"></i>Reset Password</div>
      <form action="/admin/users/<%= profile._id %>/reset-password" method="POST">
        <div class="mb-3">
          <label class="form-label fw-bold" style="font-size:.82rem;">New Password (min 6 chars)</label>
          <input type="password" name="newPassword" class="form-control" required minlength="6" placeholder="Enter new password" style="border-radius:10px;border:2px solid #e5e7eb;"/>
        </div>
        <button type="submit" class="btn btn-warning w-100" style="border-radius:10px;font-family:'DM Sans',sans-serif;font-weight:600;">
          <i class="bi bi-key me-2"></i>Reset Password
        </button>
      </form>
    </div>

    <!-- Ban Section -->
    <div class="admin-card" id="banSection">
      <div class="admin-card-title" style="color:#ef4444;"><i class="bi bi-ban"></i>Ban / Suspend</div>
      <% if(!profile.isBanned) { %>
        <form action="/admin/users/<%= profile._id %>/ban" method="POST">
          <div class="mb-3">
            <label class="form-label fw-bold" style="font-size:.82rem;">Ban Reason (optional)</label>
            <textarea name="reason" class="form-control" rows="3" placeholder="Spam, fake account, abuse…" style="border-radius:10px;border:2px solid #e5e7eb;"></textarea>
          </div>
          <button type="submit" class="btn btn-danger w-100" style="border-radius:10px;font-family:'DM Sans',sans-serif;font-weight:600;">
            <i class="bi bi-ban me-2"></i>Ban This User
          </button>
        </form>
      <% } else { %>
        <div class="alert alert-warning mb-3">
          <i class="bi bi-exclamation-triangle me-2"></i>
          This user is currently banned.<% if(profile.banReason){ %> Reason: <strong><%= profile.banReason %></strong><% } %>
        </div>
        <form action="/admin/users/<%= profile._id %>/unban" method="POST">
          <button type="submit" class="btn btn-success w-100" style="border-radius:10px;font-family:'DM Sans',sans-serif;font-weight:600;">
            <i class="bi bi-unlock me-2"></i>Remove Ban
          </button>
        </form>
      <% } %>
    </div>

    <!-- Delete -->
    <div class="admin-card" style="border:2px solid #fee2e2;">
      <div class="admin-card-title" style="color:#ef4444;"><i class="bi bi-trash3"></i>Danger Zone</div>
      <p style="font-size:.85rem;color:#6b7280;">Permanently delete this user account. This cannot be undone.</p>
      <form action="/admin/users/<%= profile._id %>/delete" method="POST"
        onsubmit="return confirm('Permanently delete <%= profile.name.replace(/'/g,'') %>? This cannot be undone.')">
        <button type="submit" class="btn btn-danger w-100" style="border-radius:10px;font-family:'DM Sans',sans-serif;font-weight:600;">
          <i class="bi bi-trash3 me-2"></i>Delete Account
        </button>
      </form>
    </div>
  </div>

  <!-- Donation history -->
  <div class="col-lg-8">
    <div class="admin-card">
      <div class="admin-card-title">
        <i class="bi bi-box-seam text-warning"></i>
        <%= profile.role === 'donor' ? 'Donations Made' : 'Deliveries Handled' %>
        <span style="margin-left:auto;background:#f3f4f6;padding:4px 12px;border-radius:12px;font-size:.78rem;font-weight:700;"><%= donations.length %></span>
      </div>
      <% if(donations.length === 0) { %>
        <div style="text-align:center;padding:40px;color:#9ca3af;">
          <div style="font-size:2.5rem;">📭</div>
          <p>No donations <%= profile.role === 'donor' ? 'made' : 'handled' %> yet.</p>
        </div>
      <% } else { %>
        <div style="overflow-x:auto;">
          <table class="admin-table">
            <thead><tr>
              <th>Food</th>
              <% if(profile.role==='ngo'){ %><th>Donor</th><% } else { %><th>NGO</th><% } %>
              <th>Qty</th><th>Status</th><th>Date</th><th></th>
            </tr></thead>
            <tbody>
              <% donations.forEach(d => { %>
              <tr>
                <td><strong><%= d.name %></strong></td>
                <td style="font-size:.82rem;color:#6b7280;"><%= profile.role==='ngo' ? (d.donorName||'—') : (d.ngoName||'<span style="color:#d1d5db;">Pending</span>') %></td>
                <td style="font-size:.82rem;"><%= d.quantity %></td>
                <td><span class="status-badge status-<%= d.status %>"><%= d.status.replace('_',' ') %></span></td>
                <td style="font-size:.78rem;color:#6b7280;white-space:nowrap;">
                  <%= new Date(d.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                </td>
                <td><a href="/admin/donations/<%= d._id %>" class="btn-admin-sm btn-info-sm"><i class="bi bi-eye"></i></a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>


<%- include('layout-end') %>
