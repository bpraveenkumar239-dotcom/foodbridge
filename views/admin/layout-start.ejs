<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="theme-color" content="#0f2a1a"/>
  <title><%= title || 'Admin – FoodBridge' %></title>
  <link rel="manifest" href="/manifest.json"/>
  <link rel="icon" type="image/png" href="/images/favicon.png"/>
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <link rel="stylesheet" href="/css/style.css"/>
  <style>
    /* ── Admin Layout ── */
    *{box-sizing:border-box;}
    html,body{height:100%;margin:0;padding:0;overflow-x:hidden;}
    body{font-family:'DM Sans',sans-serif;background:#f0f4f0;display:flex;flex-direction:column;}

    .admin-shell{display:flex;flex:1;min-height:100vh;position:relative;}

    /* ── Overlay for mobile ── */
    #sidebarOverlay{
      display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);
      z-index:199;
    }
    #sidebarOverlay.show{display:block;}

    /* ── Sidebar ── */
    .admin-sidebar{
      width:240px;flex-shrink:0;
      background:linear-gradient(180deg,#0f2a1a 0%,#1a4a2e 100%);
      display:flex;flex-direction:column;
      position:sticky;top:0;height:100vh;overflow-y:auto;
      z-index:200;transition:transform .3s ease;
      /* ensure sidebar is NEVER cut off */
      min-height:100vh;
    }
    .sidebar-brand{
      padding:20px 16px 14px;border-bottom:1px solid rgba(255,255,255,.1);
      display:flex;align-items:center;gap:10px;flex-shrink:0;
    }
    .sidebar-brand-icon{font-size:1.7rem;}
    .sidebar-brand-text{font-family:'Playfair Display',serif;color:#fff;font-size:1.05rem;font-weight:700;line-height:1.2;}
    .sidebar-brand-sub{font-size:.62rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.8px;}

    .sidebar-section{padding:14px 12px 4px;font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.35);}

    .sidebar-nav{list-style:none;padding:0 8px;margin:0;}
    .sidebar-nav li{margin-bottom:2px;}
    .sidebar-nav a{
      display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;
      color:rgba(255,255,255,.8);text-decoration:none;font-size:.86rem;font-weight:500;
      transition:all .2s;min-height:44px;
    }
    .sidebar-nav a:hover,.sidebar-nav a:active{background:rgba(255,255,255,.12);color:#fff;}
    .sidebar-nav a.active{background:rgba(255,255,255,.18);color:#fff;font-weight:700;}
    .sidebar-nav a i{font-size:.95rem;width:20px;text-align:center;flex-shrink:0;}

    .sidebar-footer{
      margin-top:auto;padding:14px 16px;
      border-top:1px solid rgba(255,255,255,.1);
      display:flex;align-items:center;gap:10px;flex-shrink:0;
    }
    .sidebar-avatar{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0;}
    .sidebar-user-name{font-size:.8rem;color:#fff;font-weight:600;line-height:1.2;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
    .sidebar-user-role{font-size:.65rem;color:rgba(255,255,255,.5);}
    .sidebar-logout{
      color:rgba(255,200,200,.8);text-decoration:none;font-size:1.1rem;
      padding:8px;border-radius:8px;transition:all .2s;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
      min-width:36px;min-height:36px;
    }
    .sidebar-logout:hover{background:rgba(239,68,68,.2);color:#fca5a5;}

    /* ── Main area ── */
    .admin-main{flex:1;display:flex;flex-direction:column;min-width:0;overflow-x:hidden;}

    /* ── Top bar ── */
    .admin-topbar{
      background:#fff;border-bottom:1px solid #e5e7eb;
      padding:12px 20px;display:flex;align-items:center;
      justify-content:space-between;flex-wrap:nowrap;gap:10px;
      position:sticky;top:0;z-index:50;
    }
    .topbar-title{font-family:'Playfair Display',serif;font-size:1.2rem;color:#1a4a2e;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .topbar-right{display:flex;align-items:center;gap:10px;flex-shrink:0;}
    .topbar-time{font-size:.75rem;color:#9ca3af;white-space:nowrap;}
    #menuBtn{
      display:none;border:none;background:rgba(26,74,46,.1);color:#1a4a2e;
      border-radius:8px;padding:8px 10px;font-size:1.3rem;cursor:pointer;
      flex-shrink:0;min-width:44px;min-height:44px;align-items:center;justify-content:center;
      -webkit-tap-highlight-color:transparent;
    }

    /* ── Content ── */
    .admin-content{padding:20px;flex:1;overflow-x:hidden;}

    /* ── Stat cards ── */
    .stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:22px;}
    .astat{background:#fff;border-radius:16px;padding:18px;box-shadow:0 2px 10px rgba(0,0,0,.06);border-left:4px solid transparent;transition:all .2s;}
    .astat:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.1);}
    .astat-icon{font-size:1.8rem;margin-bottom:8px;display:block;}
    .astat-num{font-size:1.8rem;font-weight:700;font-family:'Playfair Display',serif;color:#1a4a2e;line-height:1;}
    .astat-label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6b7280;margin-top:4px;}

    /* ── Cards ── */
    .admin-card{background:#fff;border-radius:14px;padding:20px;box-shadow:0 2px 10px rgba(0,0,0,.06);margin-bottom:18px;overflow-x:auto;}
    .admin-card-title{font-size:.95rem;font-weight:700;color:#1a4a2e;margin-bottom:14px;display:flex;align-items:center;gap:8px;}

    /* ── Tables ── */
    .admin-table{width:100%;border-collapse:separate;border-spacing:0;min-width:500px;}
    .admin-table th{background:#f9fafb;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6b7280;padding:10px 12px;border-bottom:2px solid #e5e7eb;white-space:nowrap;}
    .admin-table td{padding:11px 12px;border-bottom:1px solid #f3f4f6;font-size:.84rem;vertical-align:middle;}
    .admin-table tr:last-child td{border-bottom:none;}
    .admin-table tr:hover td{background:#fafafa;}

    /* ── Badges ── */
    .role-donor  {background:#d1fae5;color:#065f46;padding:3px 10px;border-radius:12px;font-size:.7rem;font-weight:700;}
    .role-ngo    {background:#dbeafe;color:#1e40af;padding:3px 10px;border-radius:12px;font-size:.7rem;font-weight:700;}
    .role-admin  {background:#ede9fe;color:#5b21b6;padding:3px 10px;border-radius:12px;font-size:.7rem;font-weight:700;}
    .badge-banned{background:#fee2e2;color:#991b1b;padding:3px 10px;border-radius:12px;font-size:.7rem;font-weight:700;}
    .badge-active{background:#d1fae5;color:#065f46;padding:3px 10px;border-radius:12px;font-size:.7rem;font-weight:700;}

    /* ── Buttons ── */
    .btn-admin-sm{font-size:.76rem;padding:5px 11px;border-radius:8px;font-weight:600;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;white-space:nowrap;min-height:32px;}
    .btn-danger-sm {background:#fee2e2;color:#991b1b;}
    .btn-danger-sm:hover{background:#fca5a5;}
    .btn-success-sm{background:#d1fae5;color:#065f46;}
    .btn-success-sm:hover{background:#6ee7b7;}
    .btn-info-sm   {background:#dbeafe;color:#1e40af;}
    .btn-info-sm:hover{background:#93c5fd;}
    .btn-warn-sm   {background:#fef3c7;color:#92400e;}
    .btn-warn-sm:hover{background:#fde68a;}

    /* ── Filters ── */
    .filter-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;align-items:center;}
    .filter-bar input,.filter-bar select{border:2px solid #e5e7eb;border-radius:10px;padding:8px 12px;font-size:.84rem;font-family:'DM Sans',sans-serif;background:#fff;transition:border-color .2s;min-height:40px;}
    .filter-bar input:focus,.filter-bar select:focus{border-color:#2d7a4f;outline:none;}
    .btn-filter{background:#1a4a2e;color:#fff;border:none;border-radius:10px;padding:9px 18px;font-size:.84rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;min-height:40px;}
    .btn-filter:hover{background:#2d7a4f;}
    .btn-reset{background:#f3f4f6;color:#374151;border:none;border-radius:10px;padding:9px 14px;font-size:.84rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;display:inline-flex;align-items:center;min-height:40px;}

    /* ── Pagination ── */
    .admin-pagination{display:flex;gap:5px;justify-content:center;margin-top:18px;flex-wrap:wrap;}
    .admin-pagination a{padding:7px 13px;border-radius:8px;text-decoration:none;font-size:.82rem;font-weight:600;background:#fff;color:#374151;border:2px solid #e5e7eb;transition:all .2s;min-height:36px;display:inline-flex;align-items:center;}
    .admin-pagination a.active,.admin-pagination a:hover{background:#1a4a2e;color:#fff;border-color:#1a4a2e;}
    .admin-pagination a.disabled{opacity:.4;pointer-events:none;}

    /* ── Modals ── */
    .modal-content{border-radius:14px;border:none;box-shadow:0 20px 60px rgba(0,0,0,.2);}
    .modal-header{border-bottom:1px solid #f3f4f6;padding:18px 22px;}
    .modal-body  {padding:18px 22px;}
    .modal-footer{border-top:1px solid #f3f4f6;padding:14px 22px;}

    /* ══ MOBILE ══ */
    @media(max-width:900px){
      #menuBtn{display:inline-flex !important;}
      .admin-sidebar{
        position:fixed;left:0;top:0;height:100%;width:260px !important;
        transform:translateX(-100%);
        box-shadow:4px 0 24px rgba(0,0,0,.4);
      }
      .admin-sidebar.open{transform:translateX(0) !important;}
      .admin-content{padding:14px;}
      .admin-topbar{padding:10px 14px;}
      .topbar-title{font-size:1rem;}
      .stat-grid{grid-template-columns:1fr 1fr !important;gap:10px;}
      .astat{padding:14px;}
      .astat-num{font-size:1.5rem;}
      .filter-bar{flex-direction:column;}
      .filter-bar input,.filter-bar select{width:100% !important;}
      .btn-filter,.btn-reset{width:100%;justify-content:center;}
      .admin-card{padding:14px;border-radius:12px;}
    }
    @media(max-width:400px){
      .stat-grid{grid-template-columns:1fr !important;}
      .topbar-title{font-size:.88rem;}
    }
  </style>
</head>
<body>
<div id="sidebarOverlay" onclick="closeSidebar()"></div>
<div class="admin-shell">
  <!-- SIDEBAR -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <span class="sidebar-brand-icon">🌿</span>
      <div>
        <div class="sidebar-brand-text">FoodBridge</div>
        <div class="sidebar-brand-sub">Admin Panel</div>
      </div>
    </div>

    <p class="sidebar-section">Main</p>
    <ul class="sidebar-nav">
      <li><a href="/admin/dashboard" class="<%= currentPage==='dashboard'?'active':'' %>" onclick="closeSidebar()">
        <i class="bi bi-speedometer2"></i>Dashboard
      </a></li>
    </ul>

    <p class="sidebar-section">Manage</p>
    <ul class="sidebar-nav">
      <li><a href="/admin/users" class="<%= currentPage==='users'?'active':'' %>" onclick="closeSidebar()">
        <i class="bi bi-people"></i>Users
      </a></li>
      <li><a href="/admin/users?role=donor" class="<%= currentPage==='donors'?'active':'' %>" onclick="closeSidebar()">
        <i class="bi bi-hand-thumbs-up"></i>Donors
      </a></li>
      <li><a href="/admin/users?role=ngo" class="<%= currentPage==='ngos'?'active':'' %>" onclick="closeSidebar()">
        <i class="bi bi-building"></i>NGOs
      </a></li>
      <li><a href="/admin/donations" class="<%= currentPage==='donations'?'active':'' %>" onclick="closeSidebar()">
        <i class="bi bi-box-seam"></i>Donations
      </a></li>
      <li><a href="/admin/needy-locations" class="<%= currentPage==='needy'?'active':'' %>" onclick="closeSidebar()">
        <i class="bi bi-geo-alt-fill"></i>Needy Locations
      </a></li>
    </ul>

    <p class="sidebar-section">Insights</p>
    <ul class="sidebar-nav">
      <li><a href="/admin/analytics" class="<%= currentPage==='analytics'?'active':'' %>" onclick="closeSidebar()">
        <i class="bi bi-bar-chart-line"></i>Analytics
      </a></li>
    </ul>

    <p class="sidebar-section">System</p>
    <ul class="sidebar-nav">
      <li><a href="/admin/settings" class="<%= currentPage==='settings'?'active':'' %>" onclick="closeSidebar()">
        <i class="bi bi-gear"></i>Settings
      </a></li>
    </ul>

    <!-- Sidebar footer with visible logout -->
    <div class="sidebar-footer">
      <div class="sidebar-avatar">👤</div>
      <div style="flex:1;min-width:0;">
        <div class="sidebar-user-name"><%= user.name %></div>
        <div class="sidebar-user-role">Administrator</div>
      </div>
      <a href="/logout" class="sidebar-logout" title="Logout">
        <i class="bi bi-box-arrow-right"></i>
      </a>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2" style="min-width:0;">
        <button id="menuBtn" onclick="toggleSidebar()" aria-label="Menu">
          <i class="bi bi-list"></i>
        </button>
        <h1 class="topbar-title"><%= pageTitle || 'Admin Panel' %></h1>
      </div>
      <div class="topbar-right">
        <span class="topbar-time" id="adminClock"></span>
        <a href="/" style="font-size:.8rem;color:#6b7280;text-decoration:none;white-space:nowrap;">
          <i class="bi bi-arrow-left me-1"></i><span class="d-none d-md-inline">Back</span>
        </a>
        <!-- Mobile logout shortcut in topbar -->
        <a href="/logout" class="d-md-none" style="color:#ef4444;font-size:1rem;padding:6px;border-radius:8px;" title="Logout">
          <i class="bi bi-box-arrow-right"></i>
        </a>
      </div>
    </div>
    <div class="admin-content">
