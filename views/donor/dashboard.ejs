<%- include('../partials/header', {title: 'Dashboard – FoodBridge'}) %>
<%- include('../partials/navbar') %>

<div class="page-hero donor-hero">
  <div class="page-hero-content">
    <h1 class="page-hero-title">Welcome back, <span class="highlight"><%= user.name %></span></h1>
    <p class="page-hero-subtitle">Your generosity feeds communities. What would you like to do today?</p>
  </div>
</div>

<div class="container py-5">
  <!-- Personal stats row -->
  <div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
      <div class="dash-mini-stat" style="border-left-color:#22c55e;">
        <span class="dash-mini-icon">📦</span>
        <div class="dash-mini-num"><%= stats.total %></div>
        <div class="dash-mini-label">Total</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="dash-mini-stat" style="border-left-color:#3b82f6;">
        <span class="dash-mini-icon">✅</span>
        <div class="dash-mini-num"><%= stats.delivered %></div>
        <div class="dash-mini-label">Delivered</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="dash-mini-stat" style="border-left-color:#f59e0b;">
        <span class="dash-mini-icon">⏳</span>
        <div class="dash-mini-num"><%= stats.pending %></div>
        <div class="dash-mini-label">Pending</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="dash-mini-stat" style="border-left-color:#ef4444;">
        <span class="dash-mini-icon">🌱</span>
        <div class="dash-mini-num"><%= co2Saved %> kg</div>
        <div class="dash-mini-label">CO₂ Saved</div>
      </div>
    </div>
  </div>

  <!-- Main action cards -->
  <div class="row g-4 justify-content-center mb-5">
    <div class="col-md-4">
      <a href="/donor/donate" class="dashboard-card dashboard-card-primary text-decoration-none">
        <div class="dashboard-card-icon">🍱</div>
        <h3>Donate Food</h3>
        <p>Have leftover food? List it here and help someone in need. Our NGO partners will collect and deliver it.</p>
        <span class="dashboard-card-btn">Start Donation →</span>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/donor/history" class="dashboard-card dashboard-card-secondary text-decoration-none">
        <div class="dashboard-card-icon">📋</div>
        <h3>View History</h3>
        <p>Track all your past and ongoing donations. See real-time status and live NGO location.</p>
        <span class="dashboard-card-btn">View History →</span>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/donor/impact" class="dashboard-card text-decoration-none" style="border:2px solid #fde68a;">
        <div class="dashboard-card-icon">❤️</div>
        <h3>My Impact</h3>
        <p>See how many lives you've touched, CO₂ saved, badges earned, and ratings received.</p>
        <span class="dashboard-card-btn" style="color:#d97706;">View Impact →</span>
      </a>
    </div>
  </div>

  <div class="impact-section mt-2">
    <h4 class="impact-title">Why Your Donation Matters</h4>
    <div class="row g-3 mt-2">
      <div class="col-md-4"><div class="impact-card"><span class="impact-icon">🌍</span><p>1/3 of all food produced globally is wasted</p></div></div>
      <div class="col-md-4"><div class="impact-card"><span class="impact-icon">🧒</span><p>820 million people go to bed hungry every night</p></div></div>
      <div class="col-md-4"><div class="impact-card"><span class="impact-icon">♻️</span><p>Redirecting food waste reduces carbon emissions</p></div></div>
    </div>
  </div>
</div>

<style>
.dash-mini-stat { background:#fff; border-radius:14px; padding:16px 18px; box-shadow:0 2px 10px rgba(0,0,0,.06); border-left:4px solid; display:flex; align-items:center; gap:12px; }
.dash-mini-icon { font-size:1.6rem; }
.dash-mini-num  { font-size:1.5rem; font-weight:700; font-family:'Playfair Display',serif; color:#1a4a2e; line-height:1; }
.dash-mini-label{ font-size:.7rem; font-weight:600; text-transform:uppercase; color:#6b7280; margin-top:2px; }
</style>

<%- include('../partials/suggest-location-modal', { role: 'donor' }) %>
<%- include('../partials/footer') %>
