<%- include('../partials/header', {title: 'Delivery Location – FoodBridge'}) %>
<%- include('../partials/navbar') %>

<div class="page-section">
  <div class="container py-5">
    <div class="section-header">
      <div class="success-badge-top"><i class="bi bi-check-circle-fill text-success me-2"></i>Donation Submitted!</div>
      <h2 class="section-title">Set Delivery Location</h2>
      <p class="section-subtitle">Where should this food be delivered? You can pick from admin-suggested needy locations or enter your own.</p>
    </div>

    <!-- Donation summary -->
    <div class="donation-summary-card mb-4">
      <div class="row align-items-center">
        <div class="col-auto"><span style="font-size:2rem;">🍱</span></div>
        <div class="col">
          <h5 class="mb-1"><%= food.name %></h5>
          <p class="mb-0 text-muted small"><i class="bi bi-geo-alt me-1"></i><%= food.pickupLocation %></p>
        </div>
        <div class="col-auto"><span class="status-badge status-pending">Pending</span></div>
      </div>
    </div>

    <!-- Needy Locations Panel -->
    <div id="needyPanel" class="mb-4">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
        <h5 style="font-family:'DM Sans',sans-serif;font-weight:700;margin:0;color:#1a4a2e;">
          <i class="bi bi-heart-fill text-danger me-2"></i>Suggested Needy Locations
          <span id="needyCount" style="background:#e8f5ee;color:#1a4a2e;font-size:.72rem;padding:2px 10px;border-radius:12px;margin-left:8px;font-weight:700;"></span>
        </h5>
        <button type="button" id="toggleNeedyMap" onclick="toggleNeedyMap()" style="background:#f3f4f6;border:2px solid #e5e7eb;border-radius:10px;padding:7px 16px;font-size:.82rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;">
          <i class="bi bi-map me-1"></i>Show on Map
        </button>
      </div>

      <!-- Loading state -->
      <div id="needyLoading" style="text-align:center;padding:24px;color:#9ca3af;">
        <div class="spinner-border spinner-border-sm text-success me-2"></div>Loading needy locations…
      </div>

      <!-- Needy location cards grid -->
      <div id="needyGrid" style="display:none;display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;margin-bottom:16px;"></div>

      <!-- Needy map -->
      <div id="needyMapContainer" style="display:none;margin-bottom:16px;">
        <div id="needyMap" style="height:320px;border-radius:14px;overflow:hidden;border:2px solid #e5e7eb;"></div>
        <p style="font-size:.78rem;color:#6b7280;margin-top:6px;"><i class="bi bi-cursor me-1"></i>Click a pin on the map to select that needy location</p>
      </div>
    </div>

    <!-- Divider -->
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
      <div style="flex:1;height:1px;background:#e5e7eb;"></div>
      <span style="font-size:.82rem;color:#9ca3af;font-weight:600;">OR ENTER YOUR OWN</span>
      <div style="flex:1;height:1px;background:#e5e7eb;"></div>
    </div>

    <!-- Manual delivery form -->
    <div class="form-card">
      <form action="/donor/delivery/<%= food._id %>" method="POST" id="deliveryForm">
        <div class="col-12">
          <label class="form-label fw-bold">Delivery Address</label>
          <div class="location-selector">
            <div class="location-tabs">
              <button type="button" class="loc-tab active" data-method="manual"><i class="bi bi-keyboard"></i> Type Manually</button>
              <button type="button" class="loc-tab" data-method="live"><i class="bi bi-geo-alt-fill"></i> My Location</button>
              <button type="button" class="loc-tab" data-method="map"><i class="bi bi-map"></i> Pick on Map</button>
            </div>
            <div class="location-input-area mt-2">
              <input type="text" class="form-control fc-custom" name="deliveryLocation" id="delivLocText"
                placeholder="Enter delivery address…"/>
              <input type="hidden" name="deliveryLatitude"  id="delivLat"/>
              <input type="hidden" name="deliveryLongitude" id="delivLng"/>

              <div id="liveStatus" class="location-status mt-2" style="display:none;">
                <div class="spinner-border spinner-border-sm text-success me-2"></div>Detecting location…
              </div>
              <div id="delivMapContainer" class="mt-3" style="display:none;">
                <div id="delivMap" style="height:300px;border-radius:12px;"></div>
                <p class="map-hint"><i class="bi bi-cursor me-1"></i>Click to set delivery location</p>
              </div>
            </div>
          </div>
        </div>

        <div class="form-actions mt-4">
          <button type="submit" class="btn btn-primary btn-lg btn-submit">
            <i class="bi bi-check2-circle me-2"></i>Save Delivery Location
          </button>
          <a href="/donor/skip-delivery/<%= food._id %>" class="btn btn-ghost ms-3">
            <i class="bi bi-skip-forward me-1"></i>Skip for now
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
.needy-card {
  background:#fff;border:2px solid #e5e7eb;border-radius:12px;padding:14px 16px;
  cursor:pointer;transition:all .2s;position:relative;
}
.needy-card:hover { border-color:#22c55e;box-shadow:0 4px 16px rgba(34,197,94,.15); }
.needy-card.selected { border-color:#1a4a2e;background:#f0fdf4;box-shadow:0 4px 16px rgba(26,74,46,.2); }
.needy-card .selected-badge {
  display:none;position:absolute;top:10px;right:10px;
  background:#1a4a2e;color:#fff;font-size:.65rem;font-weight:700;
  padding:2px 8px;border-radius:10px;
}
.needy-card.selected .selected-badge { display:block; }
.needy-cat-badge { font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:8px;display:inline-block;margin-bottom:6px; }
</style>

<script>
const catColors = { orphanage:'#dbeafe', shelter:'#dcfce7', oldage:'#fef3c7', school:'#ede9fe', hospital:'#fee2e2', community:'#e0f2fe', station:'#fdf4ff', other:'#f3f4f6' };
const catText   = { orphanage:'#1e40af', shelter:'#065f46', oldage:'#92400e', school:'#5b21b6', hospital:'#991b1b', community:'#0369a1', station:'#7e22ce', other:'#374151' };
const catEmojis = { orphanage:'🏠', shelter:'🏕️', oldage:'👴', school:'🏫', hospital:'🏥', community:'🤝', station:'🚉', other:'📍' };
const catPinColors = { orphanage:'#3b82f6', shelter:'#22c55e', oldage:'#f59e0b', school:'#8b5cf6', hospital:'#ef4444', community:'#06b6d4', station:'#a855f7', other:'#6b7280' };

let allNeedyLocs = [], needyMap = null, selectedLocId = null;

// Load needy locations
fetch('/api/needy-locations')
  .then(r => r.json())
  .then(data => {
    document.getElementById('needyLoading').style.display = 'none';
    if (!data.success || !data.locations.length) {
      document.getElementById('needyPanel').innerHTML += '<p style="color:#9ca3af;font-size:.85rem;text-align:center;padding:12px;">No needy locations added by admin yet.</p>';
      return;
    }
    allNeedyLocs = data.locations;
    document.getElementById('needyCount').textContent = data.locations.length + ' locations';
    renderNeedyCards(data.locations);
  })
  .catch(() => { document.getElementById('needyLoading').style.display = 'none'; });

function renderNeedyCards(locs) {
  const grid = document.getElementById('needyGrid');
  grid.style.display = 'grid';
  grid.innerHTML = locs.map(loc => `
    <div class="needy-card" id="nc_${loc._id}" onclick="selectNeedyLocation('${loc._id}')">
      <span class="selected-badge">✓ Selected</span>
      <div class="needy-cat-badge" style="background:${catColors[loc.category]||'#f3f4f6'};color:${catText[loc.category]||'#374151'};">
        ${catEmojis[loc.category]||'📍'} ${loc.category.replace('_',' ')}
      </div>
      <div style="font-weight:700;font-size:.92rem;color:#1a4a2e;margin-bottom:4px;">${loc.name}</div>
      <div style="font-size:.78rem;color:#6b7280;margin-bottom:${loc.description?'6px':'0'};">${loc.address}</div>
      ${loc.description ? `<div style="font-size:.75rem;color:#9ca3af;">${loc.description}</div>` : ''}
      ${loc.contactPhone ? `<div style="font-size:.75rem;color:#1a4a2e;margin-top:4px;"><i class="bi bi-telephone me-1"></i>${loc.contactPhone}</div>` : ''}
      ${loc.latitude ? `<div style="font-size:.72rem;color:#22c55e;margin-top:4px;"><i class="bi bi-crosshair me-1"></i>GPS available</div>` : ''}
    </div>
  `).join('');
}

function selectNeedyLocation(id) {
  const loc = allNeedyLocs.find(l => l._id === id);
  if (!loc) return;
  selectedLocId = id;

  // Update form fields
  document.getElementById('delivLocText').value = loc.name + ', ' + loc.address;
  document.getElementById('delivLat').value = loc.latitude  || '';
  document.getElementById('delivLng').value = loc.longitude || '';

  // Highlight selected card
  document.querySelectorAll('.needy-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('nc_' + id).classList.add('selected');

  // Scroll to form
  document.getElementById('delivLocText').scrollIntoView({ behavior:'smooth', block:'center' });
  document.getElementById('delivLocText').style.borderColor = '#22c55e';
  setTimeout(() => document.getElementById('delivLocText').style.borderColor = '', 2000);
}

// Toggle needy map
let needyMapInitialized = false;
function toggleNeedyMap() {
  const container = document.getElementById('needyMapContainer');
  const btn = document.getElementById('toggleNeedyMap');
  const isVisible = container.style.display !== 'none';
  container.style.display = isVisible ? 'none' : 'block';
  btn.innerHTML = isVisible ? '<i class="bi bi-map me-1"></i>Show on Map' : '<i class="bi bi-x me-1"></i>Hide Map';

  if (!isVisible && !needyMapInitialized) {
    needyMapInitialized = true;
    needyMap = L.map('needyMap').setView([12.9716, 77.5946], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution:'© OpenStreetMap' }).addTo(needyMap);

    const pts = [];
    allNeedyLocs.forEach(loc => {
      if (!loc.latitude || !loc.longitude) return;
      const color = catPinColors[loc.category] || '#6b7280';
      const icon  = L.divIcon({ className:'', iconSize:[34,34], iconAnchor:[17,17],
        html:`<div style="background:${color};width:34px;height:34px;border-radius:50%;border:3px solid #fff;box-shadow:0 3px 10px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;font-size:15px;">${catEmojis[loc.category]||'📍'}</div>` });
      L.marker([loc.latitude, loc.longitude], { icon })
        .addTo(needyMap)
        .bindPopup(`<b>${loc.name}</b><br><small>${loc.address}</small><br><a href="#" onclick="selectNeedyLocation('${loc._id}');return false;" style="color:#1a4a2e;font-weight:700;">✓ Select this location</a>`)
        .on('click', () => selectNeedyLocation(loc._id));
      pts.push([loc.latitude, loc.longitude]);
    });

    if (pts.length === 1) needyMap.setView(pts[0], 14);
    else if (pts.length > 1) needyMap.fitBounds(L.latLngBounds(pts), { padding:[30,30] });
    setTimeout(() => needyMap.invalidateSize(), 200);
  } else if (!isVisible) {
    setTimeout(() => needyMap.invalidateSize(), 100);
  }
}

// Manual location picker
let delivMapLeaflet = null, delivMarker = null;
document.querySelectorAll('.loc-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.loc-tab').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    const method = this.dataset.method;
    document.getElementById('liveStatus').style.display    = 'none';
    document.getElementById('delivMapContainer').style.display = 'none';

    if (method === 'live') {
      document.getElementById('liveStatus').style.display = 'flex';
      navigator.geolocation.getCurrentPosition(pos => {
        const lat = pos.coords.latitude, lng = pos.coords.longitude;
        document.getElementById('delivLat').value = lat;
        document.getElementById('delivLng').value = lng;
        reverseGeocode(lat, lng, 'delivLocText');
        document.getElementById('liveStatus').style.display = 'none';
        document.querySelectorAll('.needy-card').forEach(c => c.classList.remove('selected'));
      }, () => { document.getElementById('liveStatus').innerHTML='<i class="bi bi-x-circle text-danger me-2"></i>Location denied.'; });
    } else if (method === 'map') {
      document.getElementById('delivMapContainer').style.display = 'block';
      if (!delivMapLeaflet) {
        delivMapLeaflet = L.map('delivMap').setView([12.9716,77.5946],10);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(delivMapLeaflet);
        delivMapLeaflet.on('click', e => {
          if (delivMarker) delivMapLeaflet.removeLayer(delivMarker);
          delivMarker = L.marker([e.latlng.lat, e.latlng.lng]).addTo(delivMapLeaflet);
          document.getElementById('delivLat').value = e.latlng.lat;
          document.getElementById('delivLng').value = e.latlng.lng;
          reverseGeocode(e.latlng.lat, e.latlng.lng, 'delivLocText');
          document.querySelectorAll('.needy-card').forEach(c => c.classList.remove('selected'));
        });
      } else { setTimeout(() => delivMapLeaflet.invalidateSize(), 100); }
    }
  });
});

function reverseGeocode(lat, lng, id) {
  fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`)
    .then(r => r.json())
    .then(d => { document.getElementById(id).value = d.display_name || `${lat.toFixed(4)}, ${lng.toFixed(4)}`; })
    .catch(() => { document.getElementById(id).value = `${lat.toFixed(4)}, ${lng.toFixed(4)}`; });
}
</script>

<%- include('../partials/footer') %>
